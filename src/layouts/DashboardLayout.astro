---
import "@/styles/global.css";
import { Icon } from 'astro-icon/components';
import Toast from "@/components/Toast.astro";

interface Props {
    title: string;
    actionResult?: any;
}

const { title, actionResult  } = Astro.props;

let toastInfo = null;
if (actionResult) {
    if (actionResult.data?.success) {
        toastInfo = { type: 'success', message: actionResult.data.message || 'Operación exitosa' };
    } else if (actionResult.error) {
        toastInfo = { type: 'error', message: actionResult.error.message || 'Ocurrió un error' };
    }
}

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY;


// Sesión ya resuelta en middleware (una sola vez por request)
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
const { data: profile } = await Astro.locals.supabase
    .from('players')
    .select('*')
    .eq('auth_user_id', user?.id)
    .single();

const role = profile?.role || 'player';

// 2. Opciones del menú
const menuOptions = [
    { name: 'Inicio', href: '/dashboard', icon: 'layout-dashboard', roles: ['admin', 'docente', 'preseleccion', 'player'] },

    // --- SECCIÓN: INFRAESTRUCTURA (Solo Admin) ---
    { name: 'Facultades', href: '/dashboard/facultades', icon: 'building-2', roles: ['admin'] },
    { name: 'Programas', href: '/dashboard/programas', icon: 'graduation-cap', roles: ['admin'] },
    { name: 'Materias', href: '/dashboard/materias', icon: 'book-open', roles: ['admin'] },
    { name: 'Temporadas', href: '/dashboard/temporadas', icon: 'calendar-days', roles: ['admin'] },

    // --- SECCIÓN: MOTOR DEL JUEGO (Solo Admin) ---
    { name: 'Usuarios', href: '/dashboard/usuarios', icon: 'users', roles: ['admin'] },
    { name: 'Niveles de Dinero', href: '/dashboard/niveles', icon: 'list-ordered', roles: ['admin'] },
    { name: 'Comodines', href: '/dashboard/comodines', icon: 'heart-pulse', roles: ['admin'] },
    { name: 'Modos de Juego', href: '/dashboard/modos', icon: 'settings-2', roles: ['admin'] },

    // --- SECCIÓN: CONTENIDO (Admin y Docente) ---
    { name: 'Banco de Preguntas', href: '/dashboard/preguntas', icon: 'circle-help', roles: ['admin', 'docente'] },
    { name: 'Mente más Rápida', href: '/dashboard/mente-rapida', icon: 'zap', roles: ['admin', 'docente'] },
    { name: 'Silla Caliente en vivo', href: '/dashboard/silla-caliente-en-vivo', icon: 'flame', roles: ['admin', 'docente'] },

    // --- SECCIÓN: EJECUCIÓN (Admin y Docente) ---
    { name: 'Eventos / Salones', href: '/dashboard/eventos', icon: 'gamepad-2', roles: ['admin', 'docente', 'preseleccion'] },
    { name: 'Finalistas por Programa', href: '/dashboard/finalistas', icon: 'trophy', roles: ['admin', 'docente'] },

    // --- SECCIÓN: ESTUDIANTE ---
    { name: '¡A Jugar!', href: '/play', icon: 'rocket', roles: ['player'] },
    { name: 'Ayudar a participante', href: '/play/ayudar', icon: 'users-round', roles: ['player'] },

    // --- SECCIÓN: MI CUENTA (todos) ---
    { name: 'Mi cuenta', href: '/dashboard/mi-cuenta', icon: 'user-cog', roles: ['admin', 'docente', 'preseleccion', 'player'] },
];

const filteredMenu = menuOptions.filter(opt => opt.roles.includes(role));
---

<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Unilibre Games</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" is:inline></script>
    <!-- [1] CARGAMOS LA LIBRERÍA EN EL HEAD -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

    <!-- [2] INICIALIZAMOS EL CLIENTE GLOBAL CON SESIÓN (necesario para RLS en panel de control) -->
    <script is:inline define:vars={{
        url: import.meta.env.PUBLIC_SUPABASE_URL,
        key: import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY,
        accessToken: accessToken ?? ''
    }}>
        if (typeof supabase !== 'undefined') {
            window.supabaseClient = supabase.createClient(url, key, {
                auth: { persistSession: false, autoRefreshToken: false, detectSessionInUrl: false },
                realtime: { params: { events_per_second: 10 } },
                global: accessToken ? { headers: { Authorization: 'Bearer ' + accessToken } } : {}
            });
            if (accessToken && window.supabaseClient.realtime) {
                window.supabaseClient.realtime.setAuth(accessToken);
            }
        } else {
            console.error("❌ Error: La librería Supabase no cargó desde el CDN");
        }
    </script>
</head>
<body class="bg-base-200 min-h-screen flex font-sans">
<!-- Botón menú móvil (solo visible en pantallas pequeñas) -->
<button id="btn-menu-mobile" type="button" class="md:hidden fixed top-4 left-4 z-50 btn btn-square btn-ghost bg-slate-900/90 text-white border border-slate-700 shadow-lg transition-opacity duration-300" aria-label="Abrir menú">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
</button>

<!-- Overlay para cerrar menú al hacer clic fuera -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden" aria-hidden="true"></div>

<!-- SIDEBAR -->
<aside id="sidebar" class="w-64 bg-slate-900 text-slate-300 flex flex-col border-r border-slate-800 shrink-0 fixed md:static inset-y-0 left-0 z-40 h-[100dvh] md:h-screen max-h-[100svh] -translate-x-full md:translate-x-0 transition-transform duration-300 ease-out overflow-hidden">
    <!-- Header del Sidebar (con botón cerrar en móvil) -->
    <div class="shrink-0 p-6 flex items-start justify-between gap-2">
        <div>
            <h1 class="text-white font-black text-xl italic tracking-tighter">
                UNILIBRE <span class="text-red-600 font-normal">GAMES</span>
            </h1>
            <div class="flex items-center gap-2 mt-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                <span class="text-[9px] uppercase font-bold text-slate-500 tracking-widest">{role}</span>
            </div>
        </div>
        <button id="btn-close-sidebar" type="button" class="md:hidden btn btn-ghost btn-sm btn-square text-slate-400 hover:text-white shrink-0" aria-label="Cerrar menú">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>

    <!-- Navegación (scroll en móvil cuando hay muchas opciones) -->
    <nav class="flex-1 min-h-0 overflow-y-auto overflow-x-hidden overscroll-contain px-4 py-2 space-y-1">
        {filteredMenu.map((item) => (
                <a href={item.href} class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white transition-all group">
                    <!-- Icono con color controlado: Gris por defecto, Rojo al pasar el mouse -->
                    <Icon name={`lucide:${item.icon}`} class="w-5 h-5 text-slate-400 group-hover:text-red-500 transition-colors" />
                    <span class="text-sm font-medium">{item.name}</span>
                </a>
        ))}
    </nav>

    <!-- FOOTER DEL SIDEBAR: usuario y cerrar sesión (siempre visible) -->
    <div class="shrink-0 p-4 border-t border-slate-800 bg-slate-900/50">
        <a href="/dashboard/mi-cuenta" class="flex items-center gap-3 p-3 mb-4 rounded-xl bg-slate-800/40 border border-slate-800/50 hover:bg-slate-800/60 transition-colors block">
            <div class="w-9 h-9 rounded-full bg-red-600 flex items-center justify-center text-white font-black text-sm uppercase shadow-inner">
                {profile?.name?.charAt(0) || 'U'}
            </div>
            <div class="overflow-hidden">
                <p class="text-xs text-white font-bold truncate leading-none mb-1">
                    {profile?.name || 'Usuario'}
                </p>
                <p class="text-[10px] text-slate-500 truncate leading-none">
                    {user?.email}
                </p>
            </div>
        </a>

        <form action="/api/auth/logout" method="POST">
            <button type="submit" class="btn btn-ghost btn-sm w-full justify-start text-slate-400 hover:text-red-400 hover:bg-red-400/10 gap-3 border-none normal-case">
                <Icon name="lucide:log-out" class="w-4 h-4" />
                <span>Cerrar Sesión</span>
            </button>
        </form>
    </div>
</aside>

<!-- ÁREA DE CONTENIDO -->
<main class="flex-1 flex flex-col h-screen overflow-y-auto relative pt-14 md:pt-0">

    {toastInfo && <Toast type={toastInfo.type as any} message={toastInfo.message} />}

    <div class="p-8 lg:p-12">
        <slot />
    </div>
</main>

<script is:inline>
    // Función global para desbloquear botones desde cualquier página
    window.unlockSubmitButtons = () => {
        const btns = document.querySelectorAll('button[type="submit"]');
        btns.forEach(btn => {
            btn.removeAttribute('disabled');
            btn.classList.remove('btn-disabled', 'is-loading');
        });
    };

    document.addEventListener('submit', (e) => {
        const form = e.target;
        const btn = form.querySelector('button[type="submit"]');

        // Si el formulario no es válido nativamente, no hacemos nada
        if (!form.checkValidity()) return;

        if (btn) {
            // Pequeño delay para dejar que scripts locales validen primero
            setTimeout(() => {
                if (!e.defaultPrevented) {
                    btn.setAttribute('disabled', 'true');
                    btn.classList.add('is-loading');
                }
            }, 10);
        }
    });

    // Cliente ya creado en head con sesión; solo setAuth para realtime si existe
    if (window.supabaseClient?.realtime) {
        window.supabaseClient.realtime.setAuth();
    }

    // Toggle menú lateral en móvil
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const btnMenu = document.getElementById('btn-menu-mobile');
    const btnClose = document.getElementById('btn-close-sidebar');

    function openSidebar() {
        sidebar?.classList.remove('-translate-x-full');
        overlay?.classList.remove('hidden');
        btnMenu?.classList.add('opacity-0', 'pointer-events-none');
        document.body.style.overflow = 'hidden';
    }
    function closeSidebar() {
        sidebar?.classList.add('-translate-x-full');
        overlay?.classList.add('hidden');
        btnMenu?.classList.remove('opacity-0', 'pointer-events-none');
        document.body.style.overflow = '';
    }

    btnMenu?.addEventListener('click', openSidebar);
    btnClose?.addEventListener('click', closeSidebar);
    overlay?.addEventListener('click', closeSidebar);
</script>
</body>
</html>