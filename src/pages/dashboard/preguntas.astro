---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { actions } from "astro:actions";
import { Icon } from 'astro-icon/components';
import DeleteModal from "../../components/DeleteModal.astro";
import FormButton from "../../components/FormButton.astro";
import { buildPreguntasListQuery, preguntasListPath } from "../../lib/preguntasListQuery";

const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");
const { data: profile } = await Astro.locals.supabase.from('players').select('role').eq('auth_user_id', user.id).single();
if (profile?.role !== 'admin' && profile?.role !== 'docente') return Astro.redirect("/dashboard");

const isAdmin = profile?.role === 'admin';

const saveResult = Astro.getActionResult(actions.saveQuestion);
const deleteResult = Astro.getActionResult(actions.deleteQuestion);
const bulkDeleteResult = Astro.getActionResult(actions.deleteQuestionsBulk);
const result = saveResult || deleteResult || bulkDeleteResult;

function returnQueryFromReferer(): string | null {
    const ref = Astro.request.headers.get("Referer");
    if (!ref) return null;
    try {
        const u = new URL(ref);
        if (!u.pathname.includes("/dashboard/preguntas")) return null;
        return u.search ? u.search.slice(1) : "tab=listado";
    } catch {
        return null;
    }
}

if (result) {
    const q =
        (result.data?.return_query as string | undefined) ??
        returnQueryFromReferer() ??
        buildPreguntasListQuery({ tab: "listado" });
    return Astro.redirect(preguntasListPath(q));
}

// --- LÓGICA DE FILTROS, BÚSQUEDA Y PAGINACIÓN ---
const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') === 'resumen' ? 'resumen' : 'listado';
const search = url.searchParams.get('search') || '';
const fSubject = url.searchParams.get('fSubject') || '';
const fLevel = url.searchParams.get('fLevel') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const pageSize = 10;
const from = (page - 1) * pageSize;
const to = from + pageSize - 1;

// Datos para los selectores (Filtros y Modal)
const { data: faculties } = await Astro.locals.supabase.from('faculties').select('id, name').order('name');
const { data: allPrograms } = await Astro.locals.supabase.from('programs').select('id, name, faculty_id').order('name');
const { data: levels } = await Astro.locals.supabase.from('game_levels').select('id, name, money_value').order('difficulty_order');
const { data: subjectMappingsRaw } = await Astro.locals.supabase
    .from('program_subjects')
    .select('program_id, subject_id, subjects(name)');
const subjectMappings = [...(subjectMappingsRaw || [])].sort((a, b) =>
    (a.subjects?.name || '').localeCompare(b.subjects?.name || '', 'es', { sensitivity: 'base' })
);
const { data: allSubjects } = await Astro.locals.supabase.from('subjects').select('id, name').order('name');

const programNameById = new Map((allPrograms || []).map((p) => [p.id, p.name]));
const programFacultyById = new Map((allPrograms || []).map((p) => [p.id, p.faculty_id]));
const facultyNameById = new Map((faculties || []).map((f) => [f.id, f.name]));
const subjectNameById = new Map((allSubjects || []).map((s) => [s.id, s.name]));

type SummaryRow = { label: string; count: number; detail?: string };

let questions: Record<string, unknown>[] | null = [];
let count = 0;
let totalPages = 0;

let summary: {
    total: number;
    active: number;
    inactive: number;
    global: number;
    byFaculty: SummaryRow[];
    byProgram: SummaryRow[];
    bySubject: SummaryRow[];
    bySemester: SummaryRow[];
    byLevel: SummaryRow[];
} | null = null;

if (tab === 'resumen') {
    const { data: allQ } = await Astro.locals.supabase
        .from('questions')
        .select('id, scope, program_id, faculty_id, subject_id, min_semester, max_semester, active, level_id');

    const rows = allQ || [];
    const facultyCounts = new Map<number, number>();
    const programCounts = new Map<number, number>();
    const subjectCounts = new Map<number, number>();
    const levelCounts = new Map<number, number>();
    const semesterCounts = new Map<number, number>();
    for (let s = 1; s <= 12; s++) semesterCounts.set(s, 0);

    let globalCount = 0;
    let activeCount = 0;

    for (const q of rows) {
        if (q.active !== false) activeCount++;
        if (q.scope === 'global') globalCount++;
        else if (q.scope === 'faculty' && q.faculty_id != null) {
            facultyCounts.set(q.faculty_id, (facultyCounts.get(q.faculty_id) || 0) + 1);
        } else if (q.scope === 'program' && q.program_id != null) {
            programCounts.set(q.program_id, (programCounts.get(q.program_id) || 0) + 1);
        }
        if (q.subject_id != null) {
            subjectCounts.set(q.subject_id, (subjectCounts.get(q.subject_id) || 0) + 1);
        }
        if (q.level_id != null) {
            levelCounts.set(q.level_id, (levelCounts.get(q.level_id) || 0) + 1);
        }
        const minS = q.min_semester ?? 1;
        const maxS = q.max_semester ?? 12;
        for (let s = 1; s <= 12; s++) {
            if (s >= minS && s <= maxS) {
                semesterCounts.set(s, (semesterCounts.get(s) || 0) + 1);
            }
        }
    }

    const toSortedRows = (m: Map<number, number>, names: Map<number, string>): SummaryRow[] =>
        [...m.entries()]
            .map(([id, c]) => ({ label: names.get(id) ?? `ID ${id}`, count: c }))
            .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));

    const levelNameById = new Map((levels || []).map((l) => [l.id, l.name]));

    summary = {
        total: rows.length,
        active: activeCount,
        inactive: rows.length - activeCount,
        global: globalCount,
        byFaculty: toSortedRows(facultyCounts, facultyNameById),
        byProgram: toSortedRows(programCounts, programNameById),
        bySubject: toSortedRows(subjectCounts, subjectNameById),
        bySemester: [...semesterCounts.entries()].map(([sem, c]) => ({
            label: `Semestre ${sem}`,
            count: c,
        })),
        byLevel: toSortedRows(levelCounts, levelNameById),
    };
} else {
    let query = Astro.locals.supabase
        .from('questions')
        .select('*, subjects(name), game_levels(name, money_value), answers(*), programs(name), faculties(name)', { count: 'exact' });

    if (search) query = query.ilike('question_text', `%${search}%`);
    if (fSubject) query = query.eq('subject_id', fSubject);
    if (fLevel) query = query.eq('level_id', fLevel);

    const { data: qData, count: qCount, error: qError } = await query
        .order('id', { ascending: false })
        .range(from, to);

    if (qError) console.error("Error cargando preguntas:", qError);
    questions = qData;
    count = qCount || 0;
    totalPages = Math.ceil(count / pageSize);
}

const returnQueryString = buildPreguntasListQuery({ tab, search, fSubject, fLevel, page });
const listTabHref = preguntasListPath(
    buildPreguntasListQuery({ tab: "listado", search, fSubject, fLevel, page: 1 })
);
const resumenTabHref = preguntasListPath(buildPreguntasListQuery({ tab: "resumen" }));

function scopeDetailName(q: Record<string, unknown>): string | null {
    const scope = q.scope as string | undefined;
    if (scope === 'faculty') {
        const fac = q.faculties as { name?: string } | null;
        return fac?.name ?? facultyNameById.get(q.faculty_id as number) ?? null;
    }
    if (scope === 'program') {
        const prog = q.programs as { name?: string } | null;
        return prog?.name ?? programNameById.get(q.program_id as number) ?? null;
    }
    return null;
}
---

<DashboardLayout title="Banco de Preguntas" actionResult={result}>
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <div>
            <h2 class="text-4xl font-black italic uppercase text-slate-800">Trivia Bank</h2>
            <p class="text-slate-500 font-medium">
                Gestión integral de conocimiento ({summary?.total ?? count ?? 0} total)
            </p>
        </div>
        {tab === 'listado' && (
            <button id="btn-nueva" class="btn btn-primary text-white font-bold px-8 shadow-lg shadow-primary/20">
                <Icon name="lucide:plus-circle" class="w-5 h-5" /> Nueva Pregunta
            </button>
        )}
    </div>

    <div role="tablist" class="tabs tabs-boxed bg-white border border-base-300 shadow-sm w-full max-w-md mb-8 p-1">
        <a href={listTabHref} role="tab" class:list={["tab tab-lg font-bold uppercase text-xs", tab === 'listado' && "tab-active"]}>
            <Icon name="lucide:list" class="w-4 h-4 mr-1" /> Listado
        </a>
        <a href={resumenTabHref} role="tab" class:list={["tab tab-lg font-bold uppercase text-xs", tab === 'resumen' && "tab-active"]}>
            <Icon name="lucide:bar-chart-3" class="w-4 h-4 mr-1" /> Resumen
        </a>
    </div>

    {tab === 'resumen' && summary && (
        <div class="space-y-8 mb-10" id="tab-resumen">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="bg-white rounded-2xl border border-base-300 p-5 shadow-sm">
                    <p class="text-[10px] font-black uppercase text-slate-400">Total</p>
                    <p class="text-3xl font-black text-slate-900">{summary.total}</p>
                </div>
                <div class="bg-emerald-50 rounded-2xl border border-emerald-200 p-5 shadow-sm">
                    <p class="text-[10px] font-black uppercase text-emerald-700">Globales</p>
                    <p class="text-3xl font-black text-emerald-900">{summary.global}</p>
                </div>
                <div class="bg-blue-50 rounded-2xl border border-blue-200 p-5 shadow-sm">
                    <p class="text-[10px] font-black uppercase text-blue-700">Por programa</p>
                    <p class="text-3xl font-black text-blue-900">{summary.byProgram.reduce((a, r) => a + r.count, 0)}</p>
                </div>
                <div class="bg-violet-50 rounded-2xl border border-violet-200 p-5 shadow-sm">
                    <p class="text-[10px] font-black uppercase text-violet-700">Por facultad</p>
                    <p class="text-3xl font-black text-violet-900">{summary.byFaculty.reduce((a, r) => a + r.count, 0)}</p>
                </div>
            </div>
            <p class="text-xs text-slate-500">
                Activas: <strong>{summary.active}</strong> · Inactivas: <strong>{summary.inactive}</strong>.
                Por semestre: preguntas cuyo rango min–max incluye ese semestre.
            </p>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white rounded-2xl border border-base-300 shadow-sm overflow-hidden">
                    <div class="px-5 py-4 bg-slate-50 border-b border-base-300">
                        <h3 class="font-black uppercase text-sm text-slate-800 flex items-center gap-2">
                            <Icon name="lucide:graduation-cap" class="w-4 h-4 text-primary" /> Por programa
                        </h3>
                    </div>
                    {summary.byProgram.length > 0 ? (
                        <table class="table table-sm">
                            <thead><tr><th>Programa</th><th class="text-right">Preguntas</th></tr></thead>
                            <tbody>
                                {summary.byProgram.map((r) => (
                                    <tr><td class="font-medium">{r.label}</td><td class="text-right font-bold">{r.count}</td></tr>
                                ))}
                            </tbody>
                        </table>
                    ) : (
                        <p class="p-6 text-slate-400 text-sm italic">No hay preguntas con ámbito programa.</p>
                    )}
                </div>
                <div class="bg-white rounded-2xl border border-base-300 shadow-sm overflow-hidden">
                    <div class="px-5 py-4 bg-slate-50 border-b border-base-300">
                        <h3 class="font-black uppercase text-sm text-slate-800 flex items-center gap-2">
                            <Icon name="lucide:book-open" class="w-4 h-4 text-primary" /> Por asignatura
                        </h3>
                    </div>
                    {summary.bySubject.length > 0 ? (
                        <div class="max-h-72 overflow-y-auto">
                            <table class="table table-sm">
                                <thead><tr><th>Asignatura</th><th class="text-right">Preguntas</th></tr></thead>
                                <tbody>
                                    {summary.bySubject.map((r) => (
                                        <tr><td class="font-medium">{r.label}</td><td class="text-right font-bold">{r.count}</td></tr>
                                    ))}
                                </tbody>
                            </table>
                        </div>
                    ) : (
                        <p class="p-6 text-slate-400 text-sm italic">Sin asignaturas vinculadas.</p>
                    )}
                </div>
                <div class="bg-white rounded-2xl border border-base-300 shadow-sm overflow-hidden lg:col-span-2">
                    <div class="px-5 py-4 bg-slate-50 border-b border-base-300">
                        <h3 class="font-black uppercase text-sm text-slate-800 flex items-center gap-2">
                            <Icon name="lucide:calendar-range" class="w-4 h-4 text-primary" /> Por semestre
                        </h3>
                    </div>
                    <div class="p-5 grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-12 gap-2">
                        {summary.bySemester.map((r) => (
                            <div class:list={["rounded-xl border p-3 text-center", r.count > 0 ? "bg-primary/5 border-primary/30" : "bg-slate-50 border-slate-200 opacity-60"]}>
                                <p class="text-[9px] font-black uppercase text-slate-500">S{r.label.replace('Semestre ', '')}</p>
                                <p class="text-xl font-black text-slate-800">{r.count}</p>
                            </div>
                        ))}
                    </div>
                </div>
                {summary.byLevel.length > 0 && (
                    <div class="bg-white rounded-2xl border border-base-300 shadow-sm overflow-hidden lg:col-span-2">
                        <div class="px-5 py-4 bg-slate-50 border-b border-base-300">
                            <h3 class="font-black uppercase text-sm text-slate-800 flex items-center gap-2">
                                <Icon name="lucide:layers" class="w-4 h-4 text-primary" /> Por nivel
                            </h3>
                        </div>
                        <table class="table table-sm">
                            <thead><tr><th>Nivel</th><th class="text-right">Preguntas</th></tr></thead>
                            <tbody>
                                {summary.byLevel.map((r) => (
                                    <tr><td class="font-medium">{r.label}</td><td class="text-right font-bold">{r.count}</td></tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                )}
            </div>
        </div>
    )}

    {tab === 'listado' && (
    <>
    <!-- BARRA DE FILTROS REALTIME (Vía GET) -->
    <form method="GET" class="grid grid-cols-1 md:grid-cols-12 gap-3 mb-8 bg-white p-4 rounded-3xl border border-base-300 shadow-sm">
        <input type="hidden" name="tab" value="listado" />
        <div class="md:col-span-5 relative">
            <Icon name="lucide:search" class="absolute left-3 top-3 text-slate-400" />
            <input name="search" value={search} type="text" placeholder="Buscar por enunciado..." class="input input-bordered w-full pl-10 bg-base-200/50" />
        </div>
        <div class="md:col-span-3">
            <select name="fSubject" class="select select-bordered w-full font-bold text-xs uppercase">
                <option value="">Todas las Materias</option>
                {allSubjects?.map(s => <option value={s.id} selected={fSubject === String(s.id)}>{s.name}</option>)}
            </select>
        </div>
        <div class="md:col-span-2">
            <select name="fLevel" class="select select-bordered w-full font-bold text-xs uppercase">
                <option value="">Todos los Niveles</option>
                {levels?.map(l => <option value={l.id} selected={fLevel === String(l.id)}>{l.name}</option>)}
            </select>
        </div>
        <div class="md:col-span-2 flex gap-1">
            <button type="submit" class="btn btn-primary flex-1 text-white"><Icon name="lucide:filter" class="w-4 h-4" /></button>
            <a href={listTabHref} class="btn btn-ghost border border-base-300"><Icon name="lucide:rotate-ccw" class="w-4 h-4" /></a>
        </div>
    </form>

    {isAdmin && questions && questions.length > 0 && (
        <div id="bulk-bar" class="hidden mb-4 flex flex-wrap items-center gap-3 bg-red-50 border border-red-200 rounded-2xl px-5 py-3">
            <span class="text-sm font-bold text-red-900">
                <span id="bulk-count">0</span> seleccionada(s)
            </span>
            <button type="button" id="btn-bulk-delete" class="btn btn-error btn-sm text-white font-bold gap-2">
                <Icon name="lucide:trash-2" class="w-4 h-4" />
                Eliminar seleccionadas
            </button>
            <button type="button" id="btn-bulk-clear" class="btn btn-ghost btn-sm">Quitar selección</button>
        </div>
    )}

    <!-- LISTADO DE PREGUNTAS - TABLA -->
    <div class="overflow-x-auto mb-10 bg-white rounded-2xl border border-base-300 shadow-sm">
        {questions && questions.length > 0 ? (
            <table class="table table-zebra">
                <thead>
                    <tr class="bg-slate-100 text-slate-700">
                        {isAdmin && (
                            <th class="w-10">
                                <input type="checkbox" id="q-select-all" class="checkbox checkbox-sm checkbox-error" title="Seleccionar todas en esta página" />
                            </th>
                        )}
                        <th class="font-black text-xs uppercase">Pregunta</th>
                        <th class="font-black text-xs uppercase whitespace-nowrap">Scope</th>
                        <th class="font-black text-xs uppercase">Opciones de respuesta</th>
                        <th class="font-black text-xs uppercase whitespace-nowrap">Asignatura</th>
                        <th class="font-black text-xs uppercase whitespace-nowrap">Nivel</th>
                        <th class="font-black text-xs uppercase whitespace-nowrap">Semestre Min–Max</th>
                        <th class="font-black text-xs uppercase text-right w-24">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {questions.map((q) => {
                        const scopeDetail = scopeDetailName(q);
                        return (
                        <tr class="align-top hover:bg-base-200/50" data-question-row>
                            {isAdmin && (
                                <td>
                                    <input
                                        type="checkbox"
                                        class="checkbox checkbox-sm checkbox-error q-select"
                                        value={q.id}
                                        data-text={String(q.question_text).slice(0, 80)}
                                    />
                                </td>
                            )}
                            <td class="max-w-xs">
                                <p class="font-bold text-slate-800 text-sm leading-snug line-clamp-3">{q.question_text}</p>
                            </td>
                            <td>
                                <div class="flex flex-col gap-1 min-w-[7rem]">
                                    <span class:list={[
                                        "badge badge-sm font-bold uppercase text-[10px] w-fit",
                                        q.scope === 'global' && "badge-ghost",
                                        q.scope === 'faculty' && "badge-secondary",
                                        q.scope === 'program' && "badge-primary badge-outline",
                                    ]}>
                                        {q.scope === 'global' ? 'Global' : q.scope === 'faculty' ? 'Facultad' : q.scope === 'program' ? 'Programa' : q.scope}
                                    </span>
                                    {scopeDetail && (
                                        <span class="text-xs font-semibold text-slate-700 leading-tight">{scopeDetail}</span>
                                    )}
                                </div>
                            </td>
                            <td class="max-w-xs">
                                <ul class="space-y-1 text-xs">
                                    {q.answers?.map((a: any, idx: number) => (
                                        <li class:list={["flex items-start gap-2 py-0.5", a.is_correct ? "text-success font-bold" : "text-slate-500"]}>
                                            <span class="mt-0.5 flex-shrink-0">{a.is_correct ? '✓' : '○'}</span>
                                            <span class="line-clamp-2">{a.answer_text}</span>
                                        </li>
                                    ))}
                                </ul>
                            </td>
                            <td>
                                <span class="text-sm font-medium text-slate-600">{q.subjects?.name || '—'}</span>
                            </td>
                            <td>
                                <span class="text-sm font-medium text-slate-600">{q.game_levels?.name || '—'}</span>
                            </td>
                            <td>
                                <span class="text-sm font-medium text-slate-600">{q.min_semester} – {q.max_semester}</span>
                            </td>
                            <td class="text-right">
                                <div class="flex justify-end gap-1">
                                    <button class="btn btn-ghost btn-sm btn-square text-primary btn-edit"
                                        data-id={q.id}
                                        data-text={q.question_text}
                                        data-sub={q.subject_id}
                                        data-lvl={q.level_id}
                                        data-scope={q.scope}
                                        data-fac={q.faculty_id}
                                        data-prog={q.program_id}
                                        data-min={q.min_semester}
                                        data-max={q.max_semester}
                                        data-answers={JSON.stringify(q.answers)}
                                    >
                                        <Icon name="lucide:pencil" class="w-4 h-4" />
                                    </button>
                                    {isAdmin && (
                                        <button class="btn btn-ghost btn-sm btn-square text-error btn-delete" data-id={q.id} data-text={q.question_text}>
                                            <Icon name="lucide:trash-2" class="w-4 h-4" />
                                        </button>
                                    )}
                                </div>
                            </td>
                        </tr>
                        );
                    })}
                </tbody>
            </table>
        ) : (
            <div class="py-20 text-center">
                <p class="text-slate-400 italic">No se encontraron preguntas con los filtros seleccionados.</p>
            </div>
        )}
    </div>

    <!-- PAGINACIÓN DINÁMICA -->
    {totalPages > 1 && (
            <div class="flex justify-center mb-10">
                <div class="join shadow-sm bg-white border border-base-300">
                    <a href={`?tab=listado&page=${page - 1}&search=${search}&fSubject=${fSubject}&fLevel=${fLevel}`}
                       class:list={["join-item btn btn-sm", page <= 1 && "btn-disabled"]}>«</a>

                    {Array.from({length: totalPages}, (_, i) => i + 1).map(p => (
                            <a href={`?tab=listado&page=${p}&search=${search}&fSubject=${fSubject}&fLevel=${fLevel}`}
                               class:list={["join-item btn btn-sm", page === p ? "btn-primary text-white" : "btn-ghost"]}>
                                {p}
                            </a>
                    ))}

                    <a href={`?tab=listado&page=${page + 1}&search=${search}&fSubject=${fSubject}&fLevel=${fLevel}`}
                       class:list={["join-item btn btn-sm", page >= totalPages && "btn-disabled"]}>»</a>
                </div>
            </div>
    )}
    </>
    )}
    <!-- MODAL DE PREGUNTA -->
    <dialog id="modal_question" class="modal">
        <div class="modal-box max-w-4xl p-0 overflow-visible bg-base-100 border border-base-300">
            <div class="bg-primary p-6 text-white font-black text-2xl italic uppercase tracking-tighter">
                <span id="modal_title">Gestionar Pregunta</span>
            </div>

            <form method="POST" action={actions.saveQuestion} id="form-q" class="p-8 space-y-6">
                <input type="hidden" name="return_query" value={returnQueryString} />
                <input type="hidden" name="id" id="f_id" />

                <!-- FILTROS EN CASCADA -->
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-primary">1. Ámbito</span></label>
                        <select name="scope" id="f_scope" required class="select select-bordered bg-white">
                            <option value="global">Global</option>
                            <option value="faculty">Facultad</option>
                            <option value="program">Programa</option>
                        </select>
                    </div>

                    <div class="form-control" id="cont_fac">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-primary">2. Facultad</span></label>
                        <select name="faculty_id" id="f_fac" class="select select-bordered bg-white">
                            <option value="">Elegir Facultad...</option>
                            {faculties?.map(f => <option value={f.id}>{f.name}</option>)}
                        </select>
                    </div>

                    <div class="form-control" id="cont_prog">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-primary">3. Programa</span></label>
                        <select name="program_id" id="f_prog" class="select select-bordered bg-white">
                            <option value="">Elegir Programa...</option>
                            {allPrograms?.map(p => <option value={p.id} data-faculty-id={p.faculty_id}>{p.name}</option>)}
                        </select>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-primary">4. Asignatura</span></label>
                        <select name="subject_id" id="f_sub" required class="select select-bordered bg-white">
                            <option value="">Elegir Materia...</option>
                            {subjectMappings?.map(m => {
                                const facultyId = programFacultyById.get(m.program_id);
                                return (
                                    <option
                                        value={m.subject_id}
                                        data-program-id={m.program_id}
                                        data-faculty-id={facultyId ?? ''}
                                        class="hidden"
                                    >
                                        {m.subjects?.name}
                                    </option>
                                );
                            })}
                        </select>
                    </div>
                </div>

                <!-- NIVEL Y SEMESTRE -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase">Nivel / Premio</span></label>
                        <select name="level_id" id="f_lvl" required class="select select-bordered bg-base-200">
                            {levels?.map(l => <option value={l.id}>{l.name} (${l.money_value})</option>)}
                        </select>
                    </div>
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-slate-400">Semestre Min.</span></label>
                        <input type="number" name="min_semester" id="f_min" min="1" max="12" value="1" required class="input input-bordered" />
                    </div>
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-slate-400">Semestre Max.</span></label>
                        <input type="number" name="max_semester" id="f_max" min="1" max="12" value="10" required class="input input-bordered" />
                    </div>
                </div>

                <!-- PREGUNTA Y RESPUESTAS -->
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-[10px] uppercase text-primary">Pregunta</span></label>
                    <textarea name="question_text" id="f_text" required class="textarea textarea-bordered h-24 w-full font-bold text-lg" placeholder="¿...?"></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {[1,2,3,4].map(n => (
                            <div class="flex items-center gap-3 bg-base-200 p-4 rounded-2xl border border-base-300">
                                <input type="radio" name="correct_idx" value={n} class="radio radio-success" required id={`rad_${n}`} />
                                <input type="text" name={`ans_${n}`} id={`ans_${n}`} required class="input input-ghost w-full font-bold" placeholder={`Opción ${n}`} />
                            </div>
                    ))}
                </div>

                <div class="modal-action border-t border-base-300 pt-6 px-8 pb-8">
                    <button type="button" onclick="modal_question.close()" class="btn btn-ghost px-10">Cancelar</button>
                    <FormButton class="btn-primary text-white flex-1 font-black shadow-lg uppercase italic tracking-widest">Guardar Pregunta</FormButton>
                </div>
            </form>
        </div>
    </dialog>

    <DeleteModal id="modal_delete" action={actions.deleteQuestion}>
        <input type="hidden" name="return_query" value={returnQueryString} slot="extra-fields" />
    </DeleteModal>

    {isAdmin && (
        <dialog id="modal_delete_bulk" class="modal modal-bottom sm:modal-middle">
            <div class="modal-box border border-base-300 bg-base-100">
                <div class="flex items-center gap-3 text-error mb-4">
                    <Icon name="lucide:alert-triangle" class="w-8 h-8" />
                    <h3 class="font-black text-xl italic">¿ELIMINAR PREGUNTAS?</h3>
                </div>
                <p class="py-4 text-slate-600" id="modal_delete_bulk-message"></p>
                <div class="modal-action flex gap-2">
                    <button type="button" class="btn btn-ghost" onclick="document.getElementById('modal_delete_bulk').close()">
                        Cancelar
                    </button>
                    <form method="POST" action={actions.deleteQuestionsBulk} class="flex-1">
                        <input type="hidden" name="return_query" value={returnQueryString} />
                        <input type="hidden" name="ids" id="modal_delete_bulk-ids" />
                        <button type="submit" class="btn btn-error text-white w-full font-bold">
                            Confirmar eliminación
                        </button>
                    </form>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop">
                <button>close</button>
            </form>
        </dialog>
    )}
</DashboardLayout>

<script>
    const modal = document.getElementById('modal_question') as any;
    const form = document.getElementById('form-q') as HTMLFormElement;
    const scopeSelect = document.getElementById('f_scope') as HTMLSelectElement;
    const facSelect = document.getElementById('f_fac') as HTMLSelectElement;
    const progSelect = document.getElementById('f_prog') as HTMLSelectElement;
    const subSelect = document.getElementById('f_sub') as HTMLSelectElement;

    // --- REUTILIZABLE: FILTRAR VISTA ---
    function sortSubjectOptionsVisible(select: HTMLSelectElement) {
        const placeholder = select.querySelector('option[value=""]');
        const visible: HTMLOptionElement[] = [];
        select.querySelectorAll('option').forEach((opt) => {
            if (opt.value === '' || opt.classList.contains('hidden')) return;
            visible.push(opt as HTMLOptionElement);
        });
        visible.sort((a, b) =>
            (a.textContent || '').localeCompare(b.textContent || '', 'es', { sensitivity: 'base' })
        );
        visible.forEach((opt) => select.appendChild(opt));
        if (placeholder) select.insertBefore(placeholder, select.firstChild);
    }

    function filterCascade(parentId: string, childSelect: HTMLSelectElement, dataAttr: string) {
        let count = 0;
        childSelect.querySelectorAll('option').forEach(opt => {
            if (opt.value === "") return;
            const match = opt.getAttribute(dataAttr) === parentId;
            opt.classList.toggle('hidden', !match);
            if (match) count++;
        });
        if (count > 0) childSelect.value = "";
        sortSubjectOptionsVisible(childSelect);
    }

    /** Asignaturas de todos los programas de la facultad (sin duplicar materia). */
    function filterSubjectsByFaculty(facultyId: string) {
        const seenSubjectIds = new Set<string>();
        let count = 0;
        subSelect.querySelectorAll('option').forEach(opt => {
            if (opt.value === "") return;
            const match =
                facultyId !== "" &&
                opt.getAttribute('data-faculty-id') === facultyId &&
                !seenSubjectIds.has(opt.value);
            opt.classList.toggle('hidden', !match);
            if (match) {
                seenSubjectIds.add(opt.value);
                count++;
            }
        });
        if (count > 0) subSelect.value = "";
        sortSubjectOptionsVisible(subSelect);
    }

    function refreshSubjectsForScope() {
        const scope = scopeSelect.value;
        if (scope === 'global') {
            subSelect.querySelectorAll('option').forEach((opt) => {
                if (opt.value !== '') opt.classList.remove('hidden');
            });
            sortSubjectOptionsVisible(subSelect);
            return;
        }
        subSelect.querySelectorAll('option').forEach((opt) => {
            if (opt.value !== '') opt.classList.add('hidden');
        });
        if (scope === 'faculty' && facSelect.value) {
            filterSubjectsByFaculty(facSelect.value);
        } else if (scope === 'program' && progSelect.value) {
            filterCascade(progSelect.value, subSelect, 'data-program-id');
        }
    }

    // --- LOGICA DE VISIBILIDAD DE FILTROS ---
    scopeSelect.addEventListener('change', () => {
        const val = scopeSelect.value;
        document.getElementById('cont_fac')?.classList.toggle('hidden', val === 'global');
        document.getElementById('cont_prog')?.classList.toggle('hidden', val !== 'program');

        facSelect.required = (val !== 'global');
        progSelect.required = (val === 'program');

        if (val !== 'global') subSelect.value = '';
        refreshSubjectsForScope();
    });

    // --- DISPARADORES DE CASCADA ---
    facSelect.addEventListener('change', () => {
        filterCascade(facSelect.value, progSelect, 'data-faculty-id');
        if (scopeSelect.value === 'faculty') {
            filterSubjectsByFaculty(facSelect.value);
        }
    });
    progSelect.addEventListener('change', () => {
        if (scopeSelect.value === 'program') {
            filterCascade(progSelect.value, subSelect, 'data-program-id');
        }
    });

    // --- NUEVA PREGUNTA ---
    document.getElementById('btn-nueva')?.addEventListener('click', () => {
        form.reset();
        (document.getElementById('f_id') as HTMLInputElement).value = '';
        scopeSelect.dispatchEvent(new Event('change'));
        modal.showModal();
    });

    // --- EDITAR PREGUNTA ---
    document.querySelectorAll('.btn-edit').forEach(btn => {
        btn.addEventListener('click', () => {
            console.log("Iniciando edición...");
            form.reset();

            try {
                const id = btn.getAttribute('data-id');
                const subId = btn.getAttribute('data-sub');
                const scope = btn.getAttribute('data-scope');
                const facId = btn.getAttribute('data-fac');
                const progId = btn.getAttribute('data-prog');
                const min = btn.getAttribute('data-min');
                const max = btn.getAttribute('data-max');

                // PROTECCIÓN: Verificamos el JSON de respuestas
                const answersRaw = btn.getAttribute('data-answers');
                if (!answersRaw) throw new Error("No se encontraron respuestas en el atributo data-answers");

                const answers = JSON.parse(answersRaw);

                // Llenar campos básicos
                (document.getElementById('f_id') as HTMLInputElement).value = id || '';
                (document.getElementById('f_text') as HTMLTextAreaElement).value = btn.getAttribute('data-text') || '';
                (document.getElementById('f_lvl') as HTMLSelectElement).value = btn.getAttribute('data-lvl') || '';
                (document.getElementById('f_min') as HTMLInputElement).value = min || '1';
                (document.getElementById('f_max') as HTMLInputElement).value = max || '10';

                // Sincronizar UI
                scopeSelect.value = scope || 'global';
                // Disparamos el evento manualmente para ocultar/mostrar campos de fac/prog
                scopeSelect.dispatchEvent(new Event('change'));

                if (facId) {
                    facSelect.value = facId;
                    filterCascade(facId, progSelect, 'data-faculty-id');
                }
                if (progId) {
                    progSelect.value = progId;
                }
                refreshSubjectsForScope();
                subSelect.value = subId || '';

                // Llenar las 4 respuestas
                answers.forEach((ans: any, i: number) => {
                    const n = i + 1;
                    const inputAns = document.getElementById(`ans_${n}`) as HTMLInputElement;
                    const inputRad = document.getElementById(`rad_${n}`) as HTMLInputElement;

                    if (inputAns) inputAns.value = ans.answer_text;
                    if (inputRad && ans.is_correct) inputRad.checked = true;
                });

                document.getElementById('modal_title')!.innerText = 'EDITAR PREGUNTA';
                modal.showModal();

            } catch (err) {
                console.error("Error crítico al procesar la edición:", err);
                alert("Error al cargar los datos de esta pregunta. Revisa la consola (F12).");
            }
        });
    });

    // ELIMINAR
    document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const text = btn.getAttribute('data-text');
            (document.getElementById('modal_delete-input-id') as HTMLInputElement).value = id || '';
            const msgEl = document.getElementById('modal_delete-message') as HTMLElement;
            msgEl.textContent = '';
            msgEl.append('¿Eliminar pregunta: ', Object.assign(document.createElement('strong'), { textContent: `"${text || ''}"` }), '?');
            (document.getElementById('modal_delete') as any).showModal();
        });
    });

    // ELIMINACIÓN MASIVA
    const bulkBar = document.getElementById('bulk-bar');
    const bulkCount = document.getElementById('bulk-count');
    const selectAll = document.getElementById('q-select-all') as HTMLInputElement | null;
    const bulkModal = document.getElementById('modal_delete_bulk') as HTMLDialogElement | null;
    const bulkIdsInput = document.getElementById('modal_delete_bulk-ids') as HTMLInputElement | null;
    const bulkMsg = document.getElementById('modal_delete_bulk-message');

    function getSelectedCheckboxes(): HTMLInputElement[] {
        return [...document.querySelectorAll<HTMLInputElement>('.q-select:checked')];
    }

    function updateBulkUI() {
        const selected = getSelectedCheckboxes();
        const n = selected.length;
        bulkBar?.classList.toggle('hidden', n === 0);
        if (bulkCount) bulkCount.textContent = String(n);

        const total = document.querySelectorAll<HTMLInputElement>('.q-select').length;
        if (selectAll) {
            selectAll.checked = n > 0 && n === total;
            selectAll.indeterminate = n > 0 && n < total;
        }
    }

    selectAll?.addEventListener('change', () => {
        const checked = selectAll.checked;
        document.querySelectorAll<HTMLInputElement>('.q-select').forEach((cb) => {
            cb.checked = checked;
        });
        updateBulkUI();
    });

    document.querySelectorAll('.q-select').forEach((cb) => {
        cb.addEventListener('change', updateBulkUI);
    });

    document.getElementById('btn-bulk-clear')?.addEventListener('click', () => {
        document.querySelectorAll<HTMLInputElement>('.q-select').forEach((cb) => { cb.checked = false; });
        if (selectAll) {
            selectAll.checked = false;
            selectAll.indeterminate = false;
        }
        updateBulkUI();
    });

    document.getElementById('btn-bulk-delete')?.addEventListener('click', () => {
        const selected = getSelectedCheckboxes();
        if (selected.length === 0) return;

        const ids = selected.map((cb) => cb.value).join(',');
        if (bulkIdsInput) bulkIdsInput.value = ids;

        if (bulkMsg) {
            bulkMsg.textContent = '';
            const n = selected.length;
            bulkMsg.append(
                `Se eliminarán `,
                Object.assign(document.createElement('strong'), { textContent: String(n) }),
                n === 1 ? ' pregunta' : ' preguntas',
                '. Esta acción no se puede deshacer.'
            );
        }
        bulkModal?.showModal();
    });

    if (window.unlockButtons) window.unlockButtons();
</script>