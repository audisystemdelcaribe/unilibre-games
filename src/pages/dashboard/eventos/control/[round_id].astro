---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import { Icon } from 'astro-icon/components';
import { actions } from "astro:actions";
import FormButton from "@/components/FormButton.astro";
import { supabaseAdmin } from "@/lib/supabaseAdmin";
import { loadClasicoCurrentQuestion, type ClasicoAnswerOption } from "@/lib/clasicoQuestionView";
import { resolveContestantPlayerIdForClasicoRound } from "@/lib/clasicoRoundContestant";
import { loadFastestFingerAttempts } from "@/lib/fastestFingerResults";
import { seededShuffle } from "@/lib/utils";

const { round_id } = Astro.params;
const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

const { data: myProfile } = await Astro.locals.supabase
    .from('players')
    .select('role')
    .eq('auth_user_id', user.id)
    .single();
if (myProfile?.role !== 'admin' && myProfile?.role !== 'docente' && myProfile?.role !== 'preseleccion') return Astro.redirect("/dashboard");

const roundIdNum = parseInt(String(round_id), 10);
const { data: round } = await Astro.locals.supabase
    .from('event_rounds').select('*, events(*)').eq('id', Number.isNaN(roundIdNum) ? round_id : roundIdNum).single();

// Usar supabaseAdmin para evitar RLS que devuelve null en relaciones embebidas
const { data: ffRound } = await supabaseAdmin
    .from('fastest_finger_rounds')
    .select('*, fastest_finger_sequences(title)')
    .eq('event_round_id', roundIdNum)
    .maybeSingle();

/** Reto activo de Mente más Rápida (título + ítems mezclados, sin orden correcto). */
let fastestFingerChallenge: { title: string; items: { text: string }[] } | null = null;
if (ffRound?.sequence_id) {
    let challengeTitle =
        (ffRound.fastest_finger_sequences as { title?: string } | null)?.title ?? '';
    if (!challengeTitle) {
        const { data: seqRow } = await supabaseAdmin
            .from('fastest_finger_sequences')
            .select('title')
            .eq('id', ffRound.sequence_id)
            .maybeSingle();
        challengeTitle = seqRow?.title ?? '';
    }
    const { data: ffItems } = await supabaseAdmin
        .from('fastest_finger_items')
        .select('text')
        .eq('sequence_id', ffRound.sequence_id);
    if (ffItems?.length) {
        const shuffled = seededShuffle(
            ffItems.map((it) => ({ text: it.text })),
            roundIdNum * 31 + Number(ffRound.sequence_id)
        );
        fastestFingerChallenge = {
            title: challengeTitle || 'Reto de ordenamiento',
            items: shuffled,
        };
    }
}

const gameModeId = round?.events?.game_mode_id;
// Rol preseleccion: solo puede controlar rondas de Preselección
if (myProfile?.role === 'preseleccion' && gameModeId !== 1) {
    return Astro.redirect("/dashboard/eventos?error=preseleccion_only");
}
const isMenteRapida = gameModeId === 3;
const isFastestFinger = round?.status === 'fastest_finger';
const isClasico = gameModeId === 2;

let lifelines: { id: number; name: string; code: string | null; description: string | null }[] = [];
if (gameModeId === 2) {
    const { data } = await Astro.locals.supabase.from('lifelines').select('id, name, code, description').order('name', { ascending: true });
    lifelines = data || [];
}

let qText = "Cargando...";
let currentLevel: { id: number; name: string; money_value: number; difficulty_order: number; is_safe_level: boolean } | null = null;
let clasicoQuestionAnswers: ClasicoAnswerOption[] = [];
// No cargar pregunta de preselección cuando estamos en Mente más Rápida (round.current_question_id es de otra fase)
if (round?.current_question_id && round?.status !== 'fastest_finger') {
    if (gameModeId === 2) {
        const cq = await loadClasicoCurrentQuestion(supabaseAdmin, roundIdNum, round.current_question_id);
        if (cq) {
            qText = cq.question_text;
            clasicoQuestionAnswers = cq.answers;
            if (cq.level_id) {
                const { data: lvl } = await supabaseAdmin
                    .from('game_levels')
                    .select('id, name, money_value, difficulty_order, is_safe_level')
                    .eq('id', cq.level_id)
                    .maybeSingle();
                currentLevel = lvl;
            }
        }
    } else {
        const { data: q } = await Astro.locals.supabase.from('questions').select('question_text, level_id').eq('id', round.current_question_id).single();
        qText = q?.question_text || qText;
    }
    if (!currentLevel && gameModeId === 2 && round.current_question_id) {
        const { data: q } = await supabaseAdmin.from('questions').select('level_id').eq('id', round.current_question_id).single();
        if (q?.level_id) {
            const { data: lvl } = await supabaseAdmin.from('game_levels').select('id, name, money_value, difficulty_order, is_safe_level').eq('id', q.level_id).single();
            currentLevel = lvl;
        }
    }
}

let prizeLevels: { id: number; name: string; money_value: number; difficulty_order: number; is_safe_level: boolean; time_limit: number }[] = [];
if (gameModeId === 2) {
    const { data } = await Astro.locals.supabase.from('game_levels').select('id, name, money_value, difficulty_order, is_safe_level, time_limit').order('difficulty_order', { ascending: true });
    prizeLevels = data || [];
}

const formatMoney = (v: number) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(v);

// Ranking para el podio final (solo preselección; Clásico tiene vista distinta)
let rankingFinal: { score: number; total_time_ms?: number; players?: { name: string }; player_id: number }[] = [];
let clasicoResult: { name: string; score: number; levelOrder: number; levelName: string } | null = null;
if (round?.status === 'finished') {
    if (gameModeId === 2) {
        // Clásico: usar active_contestants para obtener al participante que jugó (no el de mayor score)
        const { data: ac } = await supabaseAdmin
            .from('active_contestants')
            .select('player_id')
            .eq('event_id', round.event_id)
            .maybeSingle();
        const contestantId = ac?.player_id;
        const { data: ep } = contestantId
            ? await supabaseAdmin
                .from('event_players')
                .select('player_id, score, players(name)')
                .eq('event_id', round.event_id)
                .eq('player_id', contestantId)
                .eq('classroom_group_id', round.classroom_group_id)
                .maybeSingle()
            : await supabaseAdmin
                .from('event_players')
                .select('player_id, score, players(name)')
                .eq('event_id', round.event_id)
                .eq('classroom_group_id', round.classroom_group_id)
                .order('score', { ascending: false })
                .limit(1)
                .maybeSingle();
        if (ep) {
            const { data: lastAns } = await supabaseAdmin
                .from('game_answers')
                .select('question_id')
                .eq('round_id', parseInt(round_id))
                .eq('player_id', ep.player_id)
                .order('id', { ascending: false })
                .limit(1)
                .maybeSingle();
            let levelOrder = 0;
            let levelName = '—';
            if (lastAns?.question_id) {
                const { data: q } = await supabaseAdmin.from('questions').select('level_id').eq('id', lastAns.question_id).single();
                if (q?.level_id) {
                    const { data: lvl } = await supabaseAdmin.from('game_levels').select('difficulty_order, name').eq('id', q.level_id).single();
                    if (lvl) {
                        levelOrder = lvl.difficulty_order;
                        levelName = lvl.name || `Nivel ${lvl.difficulty_order}`;
                    }
                }
            }
            clasicoResult = {
                name: (ep.players as { name?: string })?.name || 'Participante',
                score: ep.score ?? 0,
                levelOrder,
                levelName,
            };
        }
    } else {
        const { data } = await Astro.locals.supabase
            .from('event_players')
            .select('score, total_time_ms, players(name), player_id')
            .eq('event_id', round.event_id)
            .eq('classroom_group_id', round.classroom_group_id)
            .order('score', { ascending: false })
            .order('total_time_ms', { ascending: true })
            .order('player_id', { ascending: true })
            .limit(10);
        rankingFinal = data || [];
    }
}

const isWaiting = round?.status === 'waiting';
const isActive = round?.status === 'active';
const isFinished = round?.status === 'finished';

// Concursante de esta sesión de Silla Caliente (misma lógica que el listado de rondas)
let clasicoParticipantName = '';
if (isClasico && round) {
    const contestantId = await resolveContestantPlayerIdForClasicoRound(
        supabaseAdmin,
        {
            id: roundIdNum,
            event_id: round.event_id,
            verification_result: round.verification_result,
        },
        round.events?.season_id ?? null
    );
    if (contestantId) {
        const { data: pl } = await supabaseAdmin.from('players').select('name').eq('id', contestantId).single();
        clasicoParticipantName = pl?.name || 'Participante';
    }
}

// Comodines ya usados en la sesión (por ronda completa, no por pregunta)
let usedLifelines: string[] = [];
let showAudienceVotes = false; // Solo mostrar votación si el comodín fue usado para la pregunta actual
if (isClasico && (isActive || isWaiting)) {
    const { data: usage } = await supabaseAdmin
        .from('round_lifeline_usage')
        .select('lifeline_code, question_id')
        .eq('round_id', parseInt(round_id));
    usedLifelines = [...new Set((usage || []).map((u) => u.lifeline_code))];
    // La votación del público solo se muestra mientras estamos en la pregunta para la que se activó
    showAudienceVotes = !!(usage || []).find((u) => u.lifeline_code === 'publico' && u.question_id === round?.current_question_id);
}

// Cargar conectados e intentos Mente más Rápida en el servidor (solo quienes entraron con el PIN de ESTA ronda)
let initialConnected: { player_id: number; name: string }[] = [];
let initialFastestAttempts: { player_id: number; name: string; response_time_ms: number; is_correct: boolean }[] = [];
if (round && !isClasico) {
    const rId = parseInt(String(round_id), 10) || 0;
    const playerIds = new Set<number>();
    const { data: sessions } = await supabaseAdmin.from("game_sessions").select("player_id").eq("round_id", rId).eq("finished", false);
    if (sessions) sessions.forEach((s: { player_id?: number }) => s.player_id && playerIds.add(s.player_id));
    if (playerIds.size > 0) {
        const { data: players } = await supabaseAdmin.from("players").select("id, name").in("id", [...playerIds]);
        const nameMap = new Map((players || []).map((p: { id: number; name?: string }) => [p.id, p.name || "Estudiante"]));
        initialConnected = [...playerIds].map((id) => ({ player_id: id, name: nameMap.get(id) || "Estudiante" }));
    }
}
if (round?.status === "fastest_finger") {
    const { attempts } = await loadFastestFingerAttempts(supabaseAdmin, roundIdNum);
    initialFastestAttempts = attempts;
}

const result = Astro.getActionResult(actions.launchRandomQuestion) || Astro.getActionResult(actions.finishRound) || Astro.getActionResult(actions.launchFastestFinger) || Astro.getActionResult(actions.confirmWinner) || Astro.getActionResult(actions.useLifeline5050) || Astro.getActionResult(actions.useLifelineCambiarPregunta) || Astro.getActionResult(actions.useLifelineLlamada) || Astro.getActionResult(actions.useLifelinePublico) || Astro.getActionResult(actions.useLastWord) || Astro.getActionResult(actions.verifyClasicoAnswer);

// Si confirmWinner redirigió a Silla Caliente, ir al panel del evento Clásico
const confirmResult = Astro.getActionResult(actions.confirmWinner);
if (confirmResult?.data?.clasico_round_id) {
    return Astro.redirect(`/dashboard/eventos/control/${confirmResult.data.clasico_round_id}`);
}

---

<DashboardLayout title="Control de Mando" actionResult={result}>
    <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
    {result?.data?.success && result?.data?.message?.includes('Correcto') && (
        <script is:inline>
            if (typeof confetti === 'function') {
                confetti({ particleCount: 120, spread: 80, origin: { y: 0.6 }, colors: ['#22c55e', '#16a34a', '#15803d'] });
            }
        </script>
    )}

    <div class="max-w-7xl mx-auto space-y-6">

        <!-- Árbol de premios: solo para Clásico (va en el lateral). Preselección sin escala. -->

        {isFinished ? (
            isClasico ? (clasicoResult ? (
                <!-- VISTA: JUEGO FINAL (Clásico) - Resumen del participante -->
                <div class="text-center py-10 animate-in zoom-in max-w-2xl mx-auto">
                    <Icon name="lucide:trophy" class="w-24 h-24 text-yellow-500 mx-auto mb-6" />
                    <h1 class="text-4xl font-black italic uppercase mb-8">Juego Terminado</h1>
                    <div class="bg-zinc-900 border-2 border-zinc-700 p-10 rounded-[2.5rem] shadow-2xl text-left">
                        <p class="text-zinc-500 font-bold uppercase text-xs tracking-widest mb-2">Participante</p>
                        <p class="text-2xl font-black text-white mb-6">{clasicoResult.name}</p>
                        <p class="text-zinc-500 font-bold uppercase text-xs tracking-widest mb-2">Nivel alcanzado</p>
                        <p class="text-xl font-bold text-zinc-300 mb-6">{clasicoResult.levelName} (nivel {clasicoResult.levelOrder})</p>
                        <p class="text-zinc-500 font-bold uppercase text-xs tracking-widest mb-2">Premio</p>
                        <p class="text-3xl font-black text-yellow-400 tabular-nums">
                            {clasicoResult.score > 0 ? formatMoney(clasicoResult.score) : '$0'}
                        </p>
                        <p class="text-zinc-500 text-sm mt-2">
                            {clasicoResult.score > 0 ? 'Ganó dinero' : 'No alcanzó un seguro'}
                        </p>
                    </div>
                    <script is:inline define:vars={{ score: clasicoResult.score, levelOrder: clasicoResult.levelOrder }}>
                        const wonMoney = score > 0;
                        const isFullWinner = wonMoney && levelOrder >= 15;
                        if (wonMoney) {
                            if (isFullWinner) {
                                const duration = 4000;
                                const end = Date.now() + duration;
                                (function frame() {
                                    confetti({
                                        particleCount: 4,
                                        angle: 60,
                                        spread: 55,
                                        origin: { x: 0 },
                                        colors: ['#fbbf24', '#f59e0b', '#f97316', '#ea580c', '#fcd34d']
                                    });
                                    confetti({
                                        particleCount: 4,
                                        angle: 120,
                                        spread: 55,
                                        origin: { x: 1 },
                                        colors: ['#fbbf24', '#f59e0b', '#f97316', '#ea580c', '#fcd34d']
                                    });
                                    if (Date.now() < end) requestAnimationFrame(frame);
                                }());
                                setTimeout(function() {
                                    confetti({
                                        particleCount: 100,
                                        spread: 100,
                                        origin: { y: 0.5 },
                                        colors: ['#fbbf24', '#f59e0b', '#f97316', '#ea580c', '#fcd34d', '#ffffff']
                                    });
                                }, 500);
                            } else {
                                confetti({
                                    particleCount: 120,
                                    spread: 70,
                                    origin: { y: 0.6 },
                                    colors: ['#fbbf24', '#f59e0b', '#f97316']
                                });
                            }
                        }
                    </script>
                </div>
            ) : (
                <div class="text-center py-10">
                    <h1 class="text-4xl font-black italic uppercase mb-6">Juego Terminado</h1>
                    <p class="text-zinc-500">No hay datos del participante.</p>
                </div>
            )) : (
                <!-- VISTA: RANKING FINAL (Preselección) -->
                <div class="text-center py-10 animate-in zoom-in">
                    <Icon name="lucide:trophy" class="w-32 h-32 text-yellow-500 mx-auto mb-6" />
                    <h1 class="text-5xl font-black italic uppercase mb-10">Ranking Final</h1>
                    <div class="max-w-2xl mx-auto space-y-4">
                        {rankingFinal.map((r, i) => (
                                <div class:list={["flex items-center justify-between p-6 rounded-[2rem] border-2 shadow-sm", i === 0 ? "bg-zinc-900 border-yellow-500 text-white scale-105 mb-4" : "bg-white border-zinc-100"]}>
                                    <div class="flex items-center gap-6">
                                        <span class="text-2xl font-black italic text-primary">{i + 1}°</span>
                                        <span class="text-xl font-bold uppercase">{r.players?.name}</span>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-3xl font-black font-mono block">{r.score}</span>
                                        <span class="text-xs text-zinc-500 font-mono">{(r.total_time_ms ?? 0) / 1000}s</span>
                                    </div>
                                </div>
                        ))}
                    </div>
                    <script is:inline>confetti({ particleCount: 200, spread: 100, origin: { y: 0.6 } });</script>
                </div>
            )
        ) : (
            <!-- VISTA: LOBBY O JUEGO -->
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_220px] xl:grid-cols-[1fr_260px] gap-6 lg:gap-8 max-h-[100vh] min-h-0">
                    <div class="min-w-0 space-y-6 overflow-y-auto">
                        <div class="bg-zinc-900 text-white p-6 sm:p-8 lg:p-10 rounded-[2rem] lg:rounded-[3.5rem] border-b-4 lg:border-b-8 border-primary shadow-2xl">
                            {isWaiting ? (
                                    <div class="text-center">
                                        <p class="text-zinc-500 font-bold uppercase text-xs mb-4">PIN</p>
                                        <h2 class="text-9xl font-black tracking-widest">{round.session_pin}</h2>
                                        {isMenteRapida && (
                                            <p class="text-amber-400 text-sm font-bold mt-4">Modo Mente más Rápida - Solo finalistas</p>
                                        )}
                                        {isClasico && (
                                            <>
                                                <p class="text-amber-400 text-sm font-bold mt-4">Modo Silla Caliente - Clásico</p>
                                                {clasicoParticipantName && (
                                                    <p class="text-white text-xl sm:text-2xl font-black mt-4">
                                                        Concursante: <span class="text-amber-300">{clasicoParticipantName}</span>
                                                    </p>
                                                )}
                                                <div class="mt-6 p-4 bg-amber-500/20 border border-amber-500/50 rounded-2xl text-left max-w-md mx-auto">
                                                    {clasicoParticipantName ? (
                                                        <>
                                                            <p class="text-amber-400 font-black text-xs uppercase mb-1">Debe ingresar con este PIN</p>
                                                            <p class="text-2xl font-black text-white mb-3">{clasicoParticipantName}</p>
                                                        </>
                                                    ) : (
                                                        <p class="text-zinc-400 text-sm italic mb-3">Concursante aún no asignado (confirma ganador en Mente más Rápida).</p>
                                                    )}
                                                    <p class="text-amber-400 font-black text-xs uppercase mb-1">Código de acceso</p>
                                                    <p class="text-2xl font-mono font-black text-white tracking-widest">{round.session_pin}</p>
                                                    <p class="text-zinc-500 text-xs mt-2">Solo esta persona puede usar el PIN en /play. Si se desconecta, que vuelva a entrar con el mismo código.</p>
                                                </div>
                                            </>
                                        )}
                                        {isClasico && lifelines && lifelines.length > 0 && (
                                            <div class="mt-6 pt-4 border-t border-white/10">
                                                <p class="text-[10px] text-amber-400/80 uppercase font-black mb-2">Comodines</p>
                                                <div class="flex flex-wrap gap-2 justify-center">
                                                    {lifelines.map((l) => (
                                                        <span class="px-3 py-1 bg-amber-500/20 border border-amber-500/40 rounded-xl text-amber-300 text-xs font-bold">{l.name}</span>
                                                    ))}
                                                </div>
                                            </div>
                                        )}
                                    </div>
                            ) : isFastestFinger ? (
                                    <div>
                                        <h1 class="text-2xl font-bold italic text-yellow-400 mb-4">Mente más Rápida — Resultados</h1>
                                        {fastestFingerChallenge ? (
                                            <div class="mb-6 p-5 bg-white/5 border border-yellow-500/40 rounded-2xl text-left max-w-3xl">
                                                <p class="text-[10px] text-yellow-400 uppercase font-black mb-1">Vista docente — reto activo</p>
                                                <p class="text-xs text-zinc-500 mb-3">
                                                    Solo el enunciado y los ítems del reto. No se muestra el orden correcto.
                                                </p>
                                                <h2 class="text-xl md:text-2xl font-black italic text-white mb-4 leading-snug">
                                                    {fastestFingerChallenge.title}
                                                </h2>
                                                <ul class="space-y-2">
                                                    {fastestFingerChallenge.items.map((item) => (
                                                        <li class="p-3 rounded-xl border bg-zinc-800/50 border-white/10 text-zinc-200 text-sm font-medium">
                                                            <span class="min-w-0">{item.text}</span>
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        ) : (
                                            <p class="text-zinc-500 text-sm mb-4 italic">
                                                No se pudo cargar el reto. Verifica que la secuencia tenga ítems en Mente más Rápida.
                                            </p>
                                        )}
                                        <p class="text-zinc-500 text-sm mb-2">Se espera a que respondan. El ganador es quien acierta correctamente en menos tiempo.</p>
                                        <p class="text-zinc-500 text-sm mb-6">Revisa los resultados y confirma al ganador para pasar a Silla Caliente.</p>
                                        {round?.session_pin && (
                                            <div class="mb-6 p-4 bg-amber-500/20 border border-amber-500/50 rounded-2xl">
                                                <p class="text-amber-400 text-xs font-black uppercase">PIN de la sala (participantes usan /play para unirse)</p>
                                                <p class="text-3xl font-mono font-black text-white tracking-widest">{round.session_pin}</p>
                                            </div>
                                        )}
                                        <div class="flex gap-4">
                                            <div class="bg-white/5 p-4 rounded-2xl border border-white/10 flex-1 text-center">
                                                <p class="text-[10px] text-zinc-500 uppercase font-black">Respondieron</p>
                                                <p class="text-4xl font-black text-white" id="answered-count">{initialFastestAttempts.length}</p>
                                            </div>
                                        </div>
                                        <div id="ff-attempts-list" class="mt-6 space-y-2 max-h-48 overflow-y-auto">
                                            {initialFastestAttempts.length > 0 && (() => {
                                                const correct = initialFastestAttempts.filter(a => a.is_correct).sort((a,b) => a.response_time_ms - b.response_time_ms);
                                                const minT = correct.length > 0 ? correct[0].response_time_ms : null;
                                                const fastestIds = new Set(correct.filter(c => c.response_time_ms === minT).map(c => c.player_id));
                                                return initialFastestAttempts.map((a) => {
                                                    const isFastest = a.is_correct && fastestIds.has(a.player_id);
                                                    return (
                                                        <div class={`p-3 rounded-xl text-xs font-bold flex justify-between items-center ${isFastest ? 'bg-amber-500/30 text-amber-100 border-2 border-amber-400' : a.is_correct ? 'bg-green-500/20 text-green-400' : 'bg-red-500/10 text-red-400'}`}>
                                                            <span>{a.name}{isFastest ? ' 🏆' : ''}</span>
                                                            <span>{(a.response_time_ms/1000).toFixed(2)}s {a.is_correct ? '✓' : '✗'}</span>
                                                        </div>
                                                    );
                                                });
                                            })()}
                                        </div>
                                        {(() => {
                                            const correct = initialFastestAttempts.filter(a => a.is_correct).sort((a,b) => a.response_time_ms - b.response_time_ms);
                                            const hasWinner = correct.length > 0;
                                            return (
                                                <div id="ff-winner-box" class={hasWinner ? "mt-4 p-4 bg-yellow-500/20 border border-yellow-500/50 rounded-2xl" : "mt-4 p-4 bg-yellow-500/20 border border-yellow-500/50 rounded-2xl hidden"}>
                                                    <p class="text-[10px] font-black text-yellow-400 uppercase">Ganador sugerido</p>
                                                    <p id="ff-winner-name" class="text-xl font-black text-white">{hasWinner ? correct[0].name : ''}</p>
                                                    <p id="ff-winner-time" class="text-sm text-zinc-300 mt-1">{hasWinner ? 'Tiempo: ' + (correct[0].response_time_ms/1000).toFixed(2) + 's' : ''}</p>
                                                    <div class="mt-3">
                                                        <input type="hidden" id="ff-winner-round-id" value={String(round_id)} />
                                                        <input type="hidden" id="ff-winner-player-id" value={hasWinner ? String(correct[0].player_id) : ''} />
                                                        <button type="button" id="ff-confirm-winner-btn" class="btn btn-warning btn-sm">Confirmar ganador → Silla Caliente</button>
                                                    </div>
                                                </div>
                                            );
                                        })()}
                                        <div id="ff-no-winner-box" class="mt-4 hidden p-4 bg-red-500/20 border border-red-500/50 rounded-2xl">
                                            <p class="text-red-400 font-bold">Ninguno respondió correctamente.</p>
                                            <p class="text-zinc-400 text-sm mt-1">Repite la prueba de Mente más Rápida para poder seleccionar un ganador.</p>
                                        </div>
                                        <div id="ff-waiting-box" class={initialFastestAttempts.length > 0 ? "mt-4 p-4 bg-zinc-700/50 border border-zinc-600 rounded-2xl hidden" : "mt-4 p-4 bg-zinc-700/50 border border-zinc-600 rounded-2xl"}>
                                            <p class="text-zinc-400 font-bold">Esperando respuestas...</p>
                                            <p class="text-zinc-500 text-sm mt-1">El botón para confirmar ganador aparecerá cuando haya al menos un participante que respondió correctamente.</p>
                                        </div>
                                    </div>
                            ) : (
                                    <div>
                                        <p class="text-primary font-black italic uppercase text-xs mb-4">En curso:</p>
                                        {isClasico && clasicoParticipantName && (
                                            <p class="text-amber-400 font-bold text-lg mb-2">Participante: {clasicoParticipantName}</p>
                                        )}
                                        {isClasico && (
                                            <div class="mb-4 p-3 bg-amber-500/10 border border-amber-500/30 rounded-xl inline-block text-left">
                                                <p class="text-amber-400 text-[10px] font-black uppercase">PIN del concursante (si se desconecta)</p>
                                                {clasicoParticipantName && (
                                                    <p class="text-lg font-black text-white mt-1">{clasicoParticipantName}</p>
                                                )}
                                                <p class="text-xl font-mono font-black text-white tracking-widest mt-1">{round?.session_pin || '—'}</p>
                                            </div>
                                        )}
                                        <h1 class:list={["font-bold italic", isClasico ? "text-4xl md:text-5xl lg:text-6xl" : "text-3xl"]} id="question-text">{qText}</h1>
                                        {isClasico && isActive && (
                                            <div id="clasico-answers-panel" class="mt-6 p-5 bg-white/5 border border-emerald-500/30 rounded-2xl text-left max-w-3xl mx-auto">
                                                <p class="text-[10px] text-emerald-400 uppercase font-black mb-1">Vista docente</p>
                                                <p class="text-xs text-zinc-500 mb-4">Opciones en el mismo orden que ve el concursante. La correcta solo la ves tú.</p>
                                                {clasicoQuestionAnswers.length > 0 ? (
                                                    <ul id="clasico-answers-list" class="space-y-2">
                                                        {clasicoQuestionAnswers.map((a) => (
                                                            <li
                                                                class:list={[
                                                                    "p-3 rounded-xl border text-sm font-medium flex flex-wrap items-center gap-2",
                                                                    a.is_correct
                                                                        ? "bg-emerald-500/20 border-emerald-400/60 text-emerald-100"
                                                                        : "bg-zinc-800/50 border-white/10 text-zinc-300",
                                                                ]}
                                                                data-answer-id={a.id}
                                                            >
                                                                <span class="font-black text-lg w-8">{a.letter}.</span>
                                                                <span class="flex-1 min-w-[12rem]">{a.answer_text}</span>
                                                                {a.is_correct && (
                                                                    <span class="badge badge-success badge-sm font-black uppercase text-[9px]">
                                                                        Correcta
                                                                    </span>
                                                                )}
                                                            </li>
                                                        ))}
                                                    </ul>
                                                ) : (
                                                    <p id="clasico-answers-empty" class="text-zinc-500 text-sm italic">Lanza una pregunta para ver las opciones.</p>
                                                )}
                                            </div>
                                        )}
                                        {!isClasico && (
                                        <div class="mt-8 flex gap-4">
                                            <div class="bg-white/5 p-4 rounded-2xl border border-white/10 flex-1 text-center">
                                                <p class="text-[10px] text-zinc-500 uppercase font-black">Respondieron</p>
                                                <p class="text-4xl font-black text-white" id="answered-count">0</p>
                                            </div>
                                        </div>
                                        )}
                                        {isClasico && (
                                            <div id="audience-pin-box" class:list={["mt-4 p-4 bg-violet-500/20 border border-violet-500/50 rounded-2xl", !showAudienceVotes && "hidden"]}>
                                                <p class="text-[10px] text-violet-400 uppercase font-black mb-1">PIN para unirse como público</p>
                                                <p class="text-2xl font-mono font-black text-violet-300 tracking-widest">{round?.session_pin || '—'}</p>
                                                <p class="text-[10px] text-zinc-500 mt-1">Ir a <strong>Ayudar a participante</strong> en el menú o a /play/ayudar e ingresar este PIN.</p>
                                            </div>
                                        )}
                                        {isClasico && (
                                            <div id="audience-votes-box" class:list={["mt-4 p-4 bg-violet-500/20 border border-violet-500/50 rounded-2xl", !showAudienceVotes && "hidden"]}>
                                                <p class="text-[10px] text-violet-400 uppercase font-black mb-2">Votación del público</p>
                                                <div id="audience-chart" class="space-y-2 min-h-[120px]"></div>
                                            </div>
                                        )}
                                        {isClasico && (
                                            <div id="student-selection-box" class="mt-4 p-4 bg-amber-500/20 border border-amber-500/50 rounded-2xl hidden">
                                                <p class="text-[10px] text-amber-400 uppercase font-black mb-2">El estudiante marcó:</p>
                                                <p id="student-selection-text" class="text-lg font-bold text-white mb-3">—</p>
                                                <div class="flex flex-wrap gap-2">
                                                    <form method="POST" action={actions.useLastWord} class="inline" id="last-word-form">
                                                        <input type="hidden" name="round_id" value={round_id} />
                                                        <input type="hidden" name="question_id" value={round?.current_question_id} />
                                                        <button type="submit" class="btn btn-warning btn-sm text-zinc-900 font-bold" id="last-word-btn" title="Bloquea la respuesta del estudiante (fondo amarillo) y no podrá cambiarla">Última palabra</button>
                                                    </form>
                                                    <form method="POST" action={actions.verifyClasicoAnswer} class="inline">
                                                        <input type="hidden" name="round_id" value={round_id} />
                                                        <button type="submit" class="btn btn-primary btn-sm text-white font-bold">Verificar respuesta</button>
                                                    </form>
                                                </div>
                                                <p class="text-[10px] text-zinc-500 mt-2">El sistema verifica en la base de datos si es correcta o incorrecta.</p>
                                            </div>
                                        )}
                                        {isClasico && lifelines && lifelines.length > 0 && (
                                            <div class="mt-4 pt-4 border-t border-white/10">
                                                <p class="text-[10px] text-amber-400/80 uppercase font-black mb-2">Comodines — el docente activa</p>
                                                <div class="flex flex-wrap gap-2">
                                                    {lifelines.map((l) => {
                                                        const code = (l.code || '').toLowerCase();
                                                        const is5050 = code === '5050' || code.includes('50') || (l.name || '').toLowerCase().includes('50');
                                                        const isCambiar = code === 'cambiar' || code === 'saltar' || (l.name || '').toLowerCase().includes('cambiar');
                                                        const isPublico = code === 'publico' || (l.name || '').toLowerCase().includes('público') || (l.name || '').toLowerCase().includes('publico');
                                                        const isLlamada = code === 'llamada' || (l.name || '').toLowerCase().includes('llamada');
                                                        const is5050Used = is5050 && usedLifelines.includes('5050');
                                                        const isCambiarUsed = isCambiar && usedLifelines.includes('cambiar');
                                                        const isPublicoUsed = isPublico && usedLifelines.includes('publico');
                                                        const isLlamadaUsed = isLlamada && usedLifelines.includes('llamada');
                                                        if (is5050) {
                                                            return (
                                                                <form method="POST" action={actions.useLifeline5050} class="inline" onsubmit={!is5050Used ? "return confirm('¿Usar 50:50? Se quitarán 2 respuestas incorrectas al estudiante.');" : "return false;"}>
                                                                    <input type="hidden" name="round_id" value={round_id} />
                                                                    <input type="hidden" name="question_id" value={round?.current_question_id} />
                                                                    <button type="submit" disabled={is5050Used} class:list={["px-4 py-2 rounded-xl text-xs font-bold border transition-all", is5050Used ? "bg-zinc-700/50 border-zinc-600 text-zinc-500 cursor-not-allowed" : "bg-amber-500/30 border-amber-500/60 text-amber-300 hover:bg-amber-500/50"]} title="Quitar 2 respuestas incorrectas al azar">
                                                                        {l.name} {is5050Used ? '(usado)' : ''}
                                                                    </button>
                                                                </form>
                                                            );
                                                        }
                                                        if (isCambiar) {
                                                            return (
                                                                <form method="POST" action={actions.useLifelineCambiarPregunta} class="inline" onsubmit={!isCambiarUsed ? "return confirm('¿Cambiar pregunta? Se buscará otra del mismo nivel.');" : "return false;"}>
                                                                    <input type="hidden" name="round_id" value={round_id} />
                                                                    <input type="hidden" name="question_id" value={round?.current_question_id} />
                                                                    <button type="submit" disabled={isCambiarUsed} class:list={["px-4 py-2 rounded-xl text-xs font-bold border transition-all", isCambiarUsed ? "bg-zinc-700/50 border-zinc-600 text-zinc-500 cursor-not-allowed" : "bg-amber-500/30 border-amber-500/60 text-amber-300 hover:bg-amber-500/50"]} title="Buscar otra pregunta del mismo nivel">
                                                                        {l.name} {isCambiarUsed ? '(usado)' : ''}
                                                                    </button>
                                                                </form>
                                                            );
                                                        }
                                                        if (isPublico) {
                                                            return (
                                                                <button type="button" data-lifeline="publico" data-round={round_id} data-question={round?.current_question_id} disabled={isPublicoUsed} class:list={["lifeline-ajax px-4 py-2 rounded-xl text-xs font-bold border transition-all", isPublicoUsed ? "bg-zinc-700/50 border-zinc-600 text-zinc-500 cursor-not-allowed" : "bg-amber-500/30 border-amber-500/60 text-amber-300 hover:bg-amber-500/50"]} title="El público verá la votación">
                                                                    {l.name} {isPublicoUsed ? '(usado)' : ''}
                                                                </button>
                                                            );
                                                        }
                                                        if (isLlamada) {
                                                            return (
                                                                <button type="button" data-lifeline="llamada" data-round={round_id} data-question={round?.current_question_id} disabled={isLlamadaUsed} class:list={["lifeline-ajax px-4 py-2 rounded-xl text-xs font-bold border transition-all", isLlamadaUsed ? "bg-zinc-700/50 border-zinc-600 text-zinc-500 cursor-not-allowed" : "bg-amber-500/30 border-amber-500/60 text-amber-300 hover:bg-amber-500/50"]} title="Solo deshabilita al seleccionar">
                                                                    {l.name} {isLlamadaUsed ? '(usado)' : ''}
                                                                </button>
                                                            );
                                                        }
                                                        return (
                                                            <span class="px-3 py-1 bg-zinc-700/30 border border-zinc-600 rounded-xl text-zinc-500 text-xs font-bold" title="Próximamente">{l.name}</span>
                                                        );
                                                    })}
                                                </div>
                                            </div>
                                        )}
                                    </div>
                            )}
                        </div>

                        {isMenteRapida && isWaiting ? (
                            <form method="POST" action={actions.launchFastestFinger}>
                                <input type="hidden" name="round_id" value={round_id} />
                                <FormButton class="btn-warning w-full h-20 text-xl font-black shadow-xl rounded-3xl">
                                    ⚡ ACTIVAR MENTE MÁS RÁPIDA (reto aleatorio)
                                </FormButton>
                            </form>
                        ) : !isFastestFinger && (
                            <>
                                {!(isClasico && isActive) && (
                                    <>
                                        <form method="POST" action={actions.launchRandomQuestion} onsubmit={isActive ? "return confirm('¿Lanzar siguiente pregunta?');" : undefined}>
                                            <input type="hidden" name="round_id" value={round_id} />
                                            <FormButton class="btn-primary w-full h-24 text-xl font-black shadow-xl rounded-3xl">
                                                {isWaiting ? 'INICIAR JUEGO 🚀' : 'SIGUIENTE PREGUNTA ➡️'}
                                            </FormButton>
                                        </form>
                                        {isActive && (
                                            <form method="POST" action={actions.finishRound} onsubmit="return confirm('¿Terminar?')">
                                                <input type="hidden" name="round_id" value={round_id} />
                                                <button type="submit" class="btn btn-error w-full text-white font-black">FINALIZAR JUEGO</button>
                                            </form>
                                        )}
                                    </>
                                )}
                                {isClasico && isActive && (
                                    <p class="text-zinc-500 text-sm font-bold text-center py-4">Esperando que el estudiante marque una opción. Luego haz clic en Verificar respuesta.</p>
                                )}
                            </>
                        )}
                    </div>

                    <!-- LATERAL: Clásico = escalera de premios (nivel 1 abajo, toda visible sin scroll) -->
                    {isClasico && prizeLevels && prizeLevels.length > 0 ? (
                        <div class="bg-zinc-900 p-3 rounded-2xl border border-zinc-700 shadow-xl flex flex-col h-full min-h-0 max-h-[100vh] overflow-hidden">
                            <h3 class="font-black italic uppercase text-zinc-400 text-center text-xs mb-1 tracking-wider shrink-0">
                                Escalera de premios
                            </h3>
                            <div class="flex-1 flex flex-col-reverse min-h-0 gap-px overflow-hidden">
                                {prizeLevels.map((l) => {
                                    const isCurrent = currentLevel?.id === l.id;
                                    const isSafe = l.is_safe_level;
                                    return (
                                        <div class:list={[
                                            "flex items-center justify-between gap-1.5 sm:gap-2 px-1.5 sm:px-2 flex-1 min-h-0 text-zinc-300",
                                            isCurrent && "bg-primary text-white rounded font-bold",
                                            !isCurrent && isSafe && "text-zinc-200"
                                        ]}>
                                            <span class="font-black tabular-nums text-sm sm:text-base lg:text-lg xl:text-xl w-5 sm:w-6 shrink-0">{l.difficulty_order}</span>
                                            <span class="text-zinc-500 text-[10px] sm:text-xs shrink-0">◆</span>
                                            <span class="font-mono font-black text-right truncate text-xs sm:text-sm lg:text-base min-w-0">{formatMoney(l.money_value)}</span>
                                            {isSafe && !isCurrent && <Icon name="lucide:shield-check" class="w-3 h-3 text-zinc-500 shrink-0" />}
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    ) : (
                        <div class="bg-white p-8 rounded-2xl border border-zinc-200 shadow-sm flex flex-col max-h-[50vh] overflow-hidden">
                            <h3 class="font-black italic uppercase text-slate-800 border-b pb-4 mb-4 text-center">
                                {isWaiting ? 'Lobby' : isFastestFinger ? 'Participantes / Resultados' : 'Respuestas'}
                            </h3>
                            <div id="live-container" class="flex-1 overflow-y-auto space-y-2 pr-2">
                                {!isClasico && (
                                    <div id="players-grid" class="grid grid-cols-2 gap-2">
                                        {initialConnected.map((p) => (
                                            <div class="bg-blue-50 p-3 rounded-xl border border-blue-100 text-[10px] font-bold text-blue-600 text-center">{p.name}</div>
                                        ))}
                                    </div>
                                )}
                                {isFastestFinger && (
                                    <div id="ff-sidebar-attempts" class="space-y-2 mt-2">
                                        {initialFastestAttempts.length === 0 && (
                                            <p class="text-zinc-400 text-xs text-center py-2">Sin respuestas aún</p>
                                        )}
                                    </div>
                                )}
                                {isActive && <div id="responders-list" class="space-y-2 mt-2"></div>}
                            </div>
                        </div>
                    )}
                </div>
        )}
    </div>
</DashboardLayout>

<script is:inline define:vars={{ round, roundId: round_id, isWaiting, isActive, isFinished, isClasico, isFastestFinger, initialConnected, ffRoundId: ffRound?.id ?? null }}>
    let procesados = new Set(Array.isArray(initialConnected) ? initialConnected.map(p => String(p.player_id)) : []);
    let respondidosProcesados = new Set();
    let lastQuestionId = round?.current_question_id ?? null;

    async function fetchAudienceVotes() {
        const box = document.getElementById('audience-votes-box');
        const chart = document.getElementById('audience-chart');
        if (!box || !chart || !round?.current_question_id) return;
        try {
            const r = await fetch(`/api/audience-votes?round_id=${round.id}&question_id=${round.current_question_id}`);
            const data = await r.json();
            if (!data.votes) return;
            const letters = data.letters || ['A','B','C','D'];
            const total = data.total || 1;
            chart.replaceChildren();
            letters.forEach(function(l) {
                const v = data.votes[l] || 0;
                const pct = total > 0 ? Math.round((v/total)*100) : 0;
                const row = document.createElement('div');
                row.className = 'flex items-center gap-2';
                const letterSpan = document.createElement('span');
                letterSpan.className = 'w-6 font-black';
                letterSpan.textContent = String(l);
                const barWrap = document.createElement('div');
                barWrap.className = 'flex-1 h-8 bg-zinc-800 rounded-lg overflow-hidden';
                const bar = document.createElement('div');
                bar.className = 'h-full bg-violet-500 rounded-lg transition-all';
                bar.style.width = pct + '%';
                const countSpan = document.createElement('span');
                countSpan.className = 'w-12 text-right font-bold';
                countSpan.textContent = v + ' (' + pct + '%)';
                barWrap.appendChild(bar);
                row.appendChild(letterSpan);
                row.appendChild(barWrap);
                row.appendChild(countSpan);
                chart.appendChild(row);
            });
        } catch (_) {}
    }

    async function sync() {
        if (isFinished) return;

        try {
            const url = `/api/control/responders?round_id=${encodeURIComponent(roundId || round?.id || '')}&_=${Date.now()}`;
            const res = await fetch(url, { credentials: 'same-origin', cache: 'no-store', headers: { 'Cache-Control': 'no-cache', 'Pragma': 'no-cache' } });
            if (!res.ok) return;
            const data = await res.json();

            // 1. CONECTADOS (Lobby / participantes) - no en Clásico; mostrar siempre que haya panel
            if (data.connected && !isClasico) {
                const toAdd = [];
                data.connected.forEach(a => {
                    const pid = String(a.player_id);
                    if (!procesados.has(pid)) {
                        procesados.add(pid);
                        toAdd.push({ player_id: pid, name: (a.name || 'Anónimo') });
                    }
                });
                if (toAdd.length > 0) {
                    let grid = document.getElementById('players-grid');
                    if (!grid) {
                        requestAnimationFrame(() => {
                            const g = document.getElementById('players-grid');
                            if (g) toAdd.forEach(a => { const d = document.createElement('div'); d.className = "bg-blue-50 p-3 rounded-xl border border-blue-100 text-[10px] font-bold text-blue-600 text-center"; d.innerText = a.name; g.appendChild(d); });
                        });
                    } else {
                        toAdd.forEach(a => {
                            const div = document.createElement('div');
                            div.className = "bg-blue-50 p-3 rounded-xl border border-blue-100 text-[10px] font-bold text-blue-600 text-center";
                            div.innerText = a.name;
                            grid.appendChild(div);
                        });
                    }
                }
            }

            // 2. RESPONDIERON (Radar de respuestas). En cada nueva pregunta se borra la lista anterior.
            if (isActive) {
                const newQId = data.current_question_id ?? null;
                if (String(newQId) !== String(lastQuestionId)) {
                    lastQuestionId = newQId;
                    respondidosProcesados.clear();
                    const list = document.getElementById('responders-list');
                    if (list) list.innerHTML = '';
                }
                const countEl = document.getElementById('answered-count');
                const list = document.getElementById('responders-list');
                if (countEl) countEl.innerText = String((data.responders || []).length);
                if (list && !isClasico && data.responders && data.responders.length > 0) {
                    const correct = data.responders.filter(r => r.is_correct).sort((a,b) => (a.response_time_ms ?? 999999) - (b.response_time_ms ?? 999999));
                    const minTime = correct.length > 0 ? correct[0].response_time_ms : null;
                    const fastestCorrectIds = new Set(correct.filter(c => c.response_time_ms === minTime).map(c => c.player_id));
                    data.responders.forEach(r => {
                        if (!respondidosProcesados.has(r.player_id)) {
                            respondidosProcesados.add(r.player_id);
                            const div = document.createElement('div');
                            const isFastestCorrect = r.is_correct && fastestCorrectIds.has(r.player_id);
                            div.className = `p-4 rounded-2xl text-xs font-bold flex justify-between border animate-in slide-in-from-right ${isFastestCorrect ? 'bg-amber-100 text-amber-800 border-amber-400' : r.is_correct ? 'bg-green-50 text-green-700 border-green-100' : 'bg-red-50 text-red-700 border-red-100'}`;
                            const s1 = document.createElement('span');
                            s1.textContent = (r.name || 'Estudiante') + (isFastestCorrect ? ' 🏆' : '');
                            div.appendChild(s1);
                            const s2 = document.createElement('span');
                            s2.textContent = (r.response_time_ms != null ? (r.response_time_ms/1000).toFixed(2) + 's ' : '') + (r.is_correct ? '✓' : '✗');
                            div.appendChild(s2);
                            list.prepend(div);
                        }
                    });
                }
            }

            // 2b. CLÁSICO: pregunta y opciones (vista docente)
            if (isClasico && isActive && data.current_question) {
                const qEl = document.getElementById('question-text');
                if (qEl) qEl.textContent = data.current_question.question_text || qEl.textContent;
                const list = document.getElementById('clasico-answers-list');
                const panel = document.getElementById('clasico-answers-panel');
                const empty = document.getElementById('clasico-answers-empty');
                if (panel) panel.classList.remove('hidden');
                if (data.current_question.answers?.length && list) {
                    if (empty) empty.classList.add('hidden');
                    list.innerHTML = '';
                    data.current_question.answers.forEach(function(a) {
                        const li = document.createElement('li');
                        li.className = 'p-3 rounded-xl border text-sm font-medium flex flex-wrap items-center gap-2 ' +
                            (a.is_correct ? 'bg-emerald-500/20 border-emerald-400/60 text-emerald-100' : 'bg-zinc-800/50 border-white/10 text-zinc-300');
                        li.dataset.answerId = String(a.id);
                        const letter = document.createElement('span');
                        letter.className = 'font-black text-lg w-8';
                        letter.textContent = a.letter + '.';
                        const text = document.createElement('span');
                        text.className = 'flex-1 min-w-[12rem]';
                        text.textContent = a.answer_text || '';
                        li.appendChild(letter);
                        li.appendChild(text);
                        if (a.is_correct) {
                            const badge = document.createElement('span');
                            badge.className = 'badge badge-success badge-sm font-black uppercase text-[9px]';
                            badge.textContent = 'Correcta';
                            li.appendChild(badge);
                        }
                        list.appendChild(li);
                    });
                } else if (empty) {
                    empty.classList.remove('hidden');
                    if (list) list.innerHTML = '';
                }
            }

            // 2c. CLÁSICO: selección del estudiante (marcó opción)
            if (isClasico && data.student_selection) {
                const box = document.getElementById('student-selection-box');
                const text = document.getElementById('student-selection-text');
                const lastWordBtn = document.getElementById('last-word-btn');
                const lastWordForm = document.getElementById('last-word-form');
                if (box && text) {
                    const sel = data.student_selection;
                    text.textContent = `Opción ${sel.letter}: ${sel.answer_text || '(sin texto)'}`;
                    box.classList.remove('hidden');
                }
                if (data.last_word_used && lastWordBtn && lastWordForm) {
                    lastWordBtn.disabled = true;
                    lastWordBtn.textContent = 'Última palabra (usado)';
                    lastWordBtn.classList.add('btn-disabled', 'opacity-50');
                }
            }

            // 3. MENTE MÁS RÁPIDA: intentos, tiempo y ganador provisional
            if (data.status === 'fastest_finger' || isFastestFinger) {
                const ffAttempts = data.fastest_finger_attempts || [];
                const countEl = document.getElementById('answered-count');
                const attemptsList = document.getElementById('ff-attempts-list');
                const sidebarAttempts = document.getElementById('ff-sidebar-attempts');
                const winnerBox = document.getElementById('ff-winner-box');
                const winnerName = document.getElementById('ff-winner-name');
                const winnerTime = document.getElementById('ff-winner-time');
                const winnerPlayerId = document.getElementById('ff-winner-player-id');
                if (countEl) countEl.innerText = String(ffAttempts.length);
                const correct = ffAttempts.filter(a => a.is_correct).sort((a,b) => (a.response_time_ms || 0) - (b.response_time_ms || 0));
                const minTime = correct.length > 0 ? correct[0].response_time_ms : null;
                const fastestCorrectIds = new Set(correct.filter(c => c.response_time_ms === minTime).map(c => c.player_id));
                function renderFfRow(a, isDark) {
                    const div = document.createElement('div');
                    const isFastestCorrect = a.is_correct && fastestCorrectIds.has(a.player_id);
                    div.className = isDark
                        ? `p-3 rounded-xl text-xs font-bold flex justify-between items-center ${isFastestCorrect ? 'bg-amber-500/30 text-amber-100 border-2 border-amber-400' : a.is_correct ? 'bg-green-500/20 text-green-400' : 'bg-red-500/10 text-red-400'}`
                        : `p-2 rounded-lg text-[10px] font-bold flex justify-between items-center ${isFastestCorrect ? 'bg-amber-100 text-amber-900 border border-amber-400' : a.is_correct ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-600'}`;
                    const s1 = document.createElement('span');
                    s1.textContent = (a.name || 'Estudiante') + (isFastestCorrect ? ' 🏆' : '');
                    const s2 = document.createElement('span');
                    const timeSec = (a.response_time_ms != null && a.response_time_ms >= 0) ? (a.response_time_ms / 1000).toFixed(2) + 's' : '—';
                    s2.textContent = timeSec + ' ' + (a.is_correct ? '✓' : '✗');
                    div.appendChild(s1);
                    div.appendChild(s2);
                    return div;
                }
                if (attemptsList) {
                    attemptsList.innerHTML = '';
                    ffAttempts.forEach(a => attemptsList.appendChild(renderFfRow(a, true)));
                }
                if (sidebarAttempts) {
                    sidebarAttempts.innerHTML = '';
                    if (ffAttempts.length === 0) {
                        const p = document.createElement('p');
                        p.className = 'text-zinc-400 text-xs text-center py-2';
                        p.textContent = 'Sin respuestas aún';
                        sidebarAttempts.appendChild(p);
                    } else {
                        ffAttempts.forEach(a => sidebarAttempts.appendChild(renderFfRow(a, false)));
                    }
                }
                const noWinnerBox = document.getElementById('ff-no-winner-box');
                const waitingBox = document.getElementById('ff-waiting-box');
                const roundIdInput = document.getElementById('ff-winner-round-id');
                if (correct.length > 0 && winnerBox && winnerName && winnerPlayerId) {
                    winnerBox.classList.remove('hidden');
                    winnerName.textContent = correct[0].name || 'Estudiante';
                    if (winnerTime) winnerTime.textContent = 'Tiempo: ' + (correct[0].response_time_ms != null ? (correct[0].response_time_ms / 1000).toFixed(2) + 's' : '—');
                    winnerPlayerId.value = String(correct[0].player_id);
                    if (roundIdInput) roundIdInput.value = String(roundId || round?.id || '');
                    if (noWinnerBox) noWinnerBox.classList.add('hidden');
                    if (waitingBox) waitingBox.classList.add('hidden');
                } else if (ffAttempts.length > 0 && noWinnerBox) {
                    noWinnerBox.classList.remove('hidden');
                    if (winnerBox) winnerBox.classList.add('hidden');
                    if (waitingBox) waitingBox.classList.add('hidden');
                } else if (waitingBox) {
                    waitingBox.classList.remove('hidden');
                }
            }
        } catch (_) {}
    }

    // Detector de cambios (Recarga si el profe lanza otra pregunta o termina)
    setInterval(async () => {
        try {
            const res = await fetch(`/api/control/responders?round_id=${roundId || round?.id || ''}`);
            if (!res.ok) return;
            const data = await res.json();
            if (String(data.current_question_id) !== String(round.current_question_id) || data.status !== round.status) {
                window.location.reload();
            }
        } catch (_) {}
    }, 4000);

    document.querySelectorAll('.lifeline-ajax').forEach(function(btn) {
        btn.addEventListener('click', function() {
            if (btn.disabled) return;
            var code = btn.getAttribute('data-lifeline');
            var roundId = btn.getAttribute('data-round');
            var questionId = btn.getAttribute('data-question');
            if (!code || !roundId || !questionId) return;
            if (code === 'publico' && !confirm('¿Activar Ayuda del público?')) return;
            if (code === 'llamada' && !confirm('¿Usar Llamada a docente?')) return;
            btn.disabled = true;
            btn.classList.add('bg-zinc-700/50', 'border-zinc-600', 'text-zinc-500', 'cursor-not-allowed');
            btn.classList.remove('bg-amber-500/30', 'border-amber-500/60', 'text-amber-300');
            btn.textContent = btn.textContent.replace(/\s*$/, ' (usado)');
            fetch('/api/use-lifeline', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ round_id: roundId, question_id: questionId, lifeline_code: code }),
                credentials: 'same-origin'
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.error) { alert(data.error); btn.disabled = false; }
                else if (code === 'publico') {
                    var box = document.getElementById('audience-votes-box');
                    var pinBox = document.getElementById('audience-pin-box');
                    if (box) { box.classList.remove('hidden'); fetchAudienceVotes(); }
                    if (pinBox) pinBox.classList.remove('hidden');
                    if (box && !window.audienceVotesInterval) {
                        window.audienceVotesInterval = setInterval(fetchAudienceVotes, 3000);
                    }
                }
            }).catch(function() { btn.disabled = false; });
        });
    });

    // Botón Confirmar ganador → Silla Caliente (delegación para que siempre funcione)
    document.body.addEventListener('click', async function(ev) {
        var target = ev.target;
        if (!target || !target.closest) return;
        var btn = target.id === 'ff-confirm-winner-btn' ? target : target.closest('#ff-confirm-winner-btn');
        if (!btn) return;
        ev.preventDefault();
        if (!confirm('¿Confirmar ganador y pasar a Silla Caliente?')) return;
        const winnerBox = document.getElementById('ff-winner-box');
        const roundInput = (winnerBox && winnerBox.querySelector('input[id="ff-winner-round-id"]')) || document.getElementById('ff-winner-round-id');
        const playerInput = (winnerBox && winnerBox.querySelector('input[id="ff-winner-player-id"]')) || document.getElementById('ff-winner-player-id');
        let roundId = roundInput && roundInput.value ? String(roundInput.value).trim() : '';
        const playerId = playerInput && playerInput.value ? String(playerInput.value).trim() : '';
        if (!roundId) {
            const m = window.location.pathname.match(/\/control\/(\d+)/);
            if (m) roundId = m[1];
        }
        if (!roundId || !playerId) {
            alert('No hay ganador seleccionado. Comprueba que aparece el nombre del ganador arriba y que el cuadro "Ganador sugerido" está visible.');
            return;
        }
        btn.disabled = true;
        btn.textContent = 'Procesando...';
        try {
            const res = await fetch('/api/control/confirm-winner', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ round_id: String(roundId), player_id: String(playerId) }),
                credentials: 'same-origin'
            });
            let data = {};
            try {
                data = await res.json();
            } catch (_) {
                data = { error: 'Respuesta inválida del servidor' };
            }
            if (res.ok && data.clasico_round_id) {
                window.location.href = `/dashboard/eventos/control/${data.clasico_round_id}`;
                return;
            }
            alert(data.error || 'Error al confirmar ganador');
        } catch (e) {
            alert('Error de conexión. Intenta de nuevo.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Confirmar ganador → Silla Caliente';
        }
    });

    setTimeout(sync, 300);
    setInterval(sync, 1500);

    // Suscripción Realtime para detectar nuevos participantes en el lobby
    if (window.supabaseClient && !isClasico) {
        const rtRoundId = roundId || round?.id;
        if (rtRoundId) {
            const lobbyChannel = window.supabaseClient
                .channel(`lobby-${rtRoundId}`)
                .on('postgres_changes', {
                    event: 'INSERT',
                    schema: 'public',
                    table: 'game_sessions',
                    filter: `round_id=eq.${rtRoundId}`
                }, async (payload) => {
                    const newPlayerId = payload.new.player_id;
                    if (procesados.has(String(newPlayerId))) return;
                    procesados.add(String(newPlayerId));

                    const { data: player } = await window.supabaseClient
                        .from('players')
                        .select('name')
                        .eq('id', newPlayerId)
                        .single();

                    const name = player?.name || 'Estudiante';
                    const grid = document.getElementById('players-grid');
                    if (grid) {
                        const div = document.createElement('div');
                        div.className = "bg-blue-50 p-3 rounded-xl border border-blue-100 text-[10px] font-bold text-blue-600 text-center";
                        div.innerText = name;
                        grid.appendChild(div);
                    }
                    sync();
                })
                .subscribe();

            if (isFastestFinger && ffRoundId) {
                window.supabaseClient
                    .channel('ff-attempts-' + ffRoundId)
                    .on('postgres_changes', {
                        event: 'INSERT',
                        schema: 'public',
                        table: 'fastest_finger_attempts',
                        filter: 'fastest_finger_round_id=eq.' + ffRoundId
                    }, function() { sync(); })
                    .on('postgres_changes', {
                        event: 'UPDATE',
                        schema: 'public',
                        table: 'fastest_finger_attempts',
                        filter: 'fastest_finger_round_id=eq.' + ffRoundId
                    }, function() { sync(); })
                    .subscribe();
            }

            window.supabaseClient
                .channel('round-status-' + rtRoundId)
                .on('postgres_changes', {
                    event: 'UPDATE',
                    schema: 'public',
                    table: 'event_rounds',
                    filter: 'id=eq.' + rtRoundId
                }, function(payload) {
                    var newStatus = payload.new && payload.new.status;
                    if (newStatus && newStatus !== round.status) {
                        window.location.reload();
                    }
                })
                .subscribe();

            window.addEventListener('beforeunload', function() {
                lobbyChannel.unsubscribe();
            });
        }
    }

    if (document.getElementById('audience-votes-box') && !document.getElementById('audience-votes-box').classList.contains('hidden')) {
        fetchAudienceVotes();
        setInterval(fetchAudienceVotes, 3000);
    }
</script>