---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import { Icon } from 'astro-icon/components';
import { actions } from "astro:actions";

const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

const { data: myProfile } = await Astro.locals.supabase
    .from('players')
    .select('role')
    .eq('auth_user_id', user.id)
    .single();
if (myProfile?.role !== 'admin') return Astro.redirect("/dashboard");

const url = new URL(Astro.request.url);
const search = (url.searchParams.get('search') || '').trim();
const roleFilter = url.searchParams.get('role') || '';
const programFilter = url.searchParams.get('program_id') || '';

let playersQuery = Astro.locals.supabase
    .from('players')
    .select('*, programs(name)', { count: 'exact' })
    .order('name', { ascending: true });

if (search) playersQuery = playersQuery.ilike('name', `%${search}%`);
if (roleFilter) playersQuery = playersQuery.eq('role', roleFilter);
if (programFilter) {
    const pid = parseInt(programFilter);
    if (!Number.isNaN(pid)) playersQuery = playersQuery.eq('program_id', pid);
}

const { data: players, count: filteredCount } = await playersQuery;

const { count: totalCount } = await Astro.locals.supabase
    .from('players')
    .select('*', { count: 'exact', head: true });

const { data: programs } = await Astro.locals.supabase
    .from('programs')
    .select('id, name')
    .order('name', { ascending: true });

const hasFilters = !!(search || roleFilter || programFilter);

const result = Astro.getActionResult(actions.createUser)
    || Astro.getActionResult(actions.updateUserRole)
    || Astro.getActionResult(actions.updatePlayer)
    || Astro.getActionResult(actions.changePassword)
    || Astro.getActionResult(actions.deleteUser);
---

<DashboardLayout title="Gestión de Usuarios" actionResult={result}>
    <div class="flex justify-between items-end mb-8">
        <div>
            <h1 class="text-4xl font-black italic tracking-tighter text-slate-900 uppercase">
                Usuarios <span class="text-red-600">y Roles</span>
            </h1>
            <p class="text-slate-500 font-medium mt-1">Administra los accesos y privilegios del sistema.</p>
        </div>
        <button type="button" id="btn-create-user" class="btn btn-primary text-white font-bold px-6 shadow-lg shadow-red-200 shrink-0">
            <Icon name="lucide:user-plus" class="w-5 h-5" />
            Crear usuario
        </button>
    </div>

    <form method="get" class="grid grid-cols-1 md:grid-cols-12 gap-3 mb-6 bg-white p-4 rounded-2xl border border-slate-100 shadow-sm">
        <div class="md:col-span-4 relative">
            <Icon name="lucide:search" class="absolute left-3 top-3 text-slate-400 w-4 h-4" />
            <input
                name="search"
                value={search}
                type="text"
                placeholder="Buscar por nombre..."
                class="input input-bordered w-full pl-10 bg-slate-50"
            />
        </div>
        <div class="md:col-span-3">
            <select name="role" class="select select-bordered w-full font-bold text-xs uppercase bg-slate-50">
                <option value="">Todos los roles</option>
                <option value="player" selected={roleFilter === 'player'}>Estudiante</option>
                <option value="docente" selected={roleFilter === 'docente'}>Docente</option>
                <option value="preseleccion" selected={roleFilter === 'preseleccion'}>Preselección</option>
                <option value="admin" selected={roleFilter === 'admin'}>Administrador</option>
            </select>
        </div>
        <div class="md:col-span-3">
            <select name="program_id" class="select select-bordered w-full font-bold text-xs bg-slate-50">
                <option value="">Todos los programas</option>
                {programs?.map((prog) => (
                    <option value={prog.id} selected={programFilter === String(prog.id)}>
                        {prog.name}
                    </option>
                ))}
            </select>
        </div>
        <div class="md:col-span-2 flex gap-2">
            <button type="submit" class="btn btn-primary flex-1 text-white font-bold text-[10px] uppercase">
                Filtrar
            </button>
            {hasFilters && (
                <a href="/dashboard/usuarios" class="btn btn-ghost border border-slate-200" title="Limpiar filtros">
                    <Icon name="lucide:rotate-ccw" class="w-4 h-4" />
                </a>
            )}
        </div>
    </form>

    <p class="text-sm text-slate-500 font-medium mb-4">
        {hasFilters
            ? `Mostrando ${filteredCount ?? 0} de ${totalCount ?? 0} usuarios`
            : `${totalCount ?? 0} usuarios en total`}
    </p>

    <div class="bg-white rounded-[2.5rem] shadow-xl border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            {players && players.length > 0 ? (
            <table class="table table-zebra w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="py-5 px-8 text-slate-400 font-black uppercase text-[10px] tracking-widest">Usuario</th>
                        <th class="py-5 px-8 text-slate-400 font-black uppercase text-[10px] tracking-widest">Programa / Semestre</th>
                        <th class="py-5 px-8 text-slate-400 font-black uppercase text-[10px] tracking-widest text-center">Rol Actual</th>
                        <th class="py-5 px-8 text-slate-400 font-black uppercase text-[10px] tracking-widest text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    {players?.map((p) => (
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="py-4 px-8">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-2xl bg-slate-100 flex items-center justify-center font-black text-slate-400 uppercase text-sm group-hover:bg-red-100 group-hover:text-red-600 transition-colors">
                                        {p.name.charAt(0)}
                                    </div>
                                    <div>
                                        <p class="font-bold text-slate-900 leading-none mb-1">{p.name}</p>
                                        <p class="text-xs text-slate-400 font-medium">ID: {p.id}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-8">
                                <p class="text-sm font-bold text-slate-700">{p.programs?.name || 'N/A'}</p>
                                <p class="text-[10px] font-black uppercase text-slate-400 tracking-tighter italic">Semestre {p.semester || '?'}</p>
                            </td>
                            <td class="py-4 px-8 text-center">
                                <span class:list={[
                                    "px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border",
                                    p.role === 'admin' ? "bg-red-50 text-red-600 border-red-100" : 
                                    p.role === 'docente' ? "bg-blue-50 text-blue-600 border-blue-100" : 
                                    p.role === 'preseleccion' ? "bg-amber-50 text-amber-600 border-amber-100" :
                                    "bg-emerald-50 text-emerald-600 border-emerald-100"
                                ]}>
                                    {p.role}
                                </span>
                            </td>
                            <td class="py-4 px-8 text-right">
                                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button 
                                        class="btn btn-square btn-ghost btn-sm text-slate-400 hover:text-amber-600 hover:bg-amber-50"
                                        data-action="edit"
                                        data-id={p.id}
                                        data-name={p.name}
                                        data-program-id={p.program_id ?? ''}
                                        data-semester={p.semester ?? ''}
                                        title="Editar Usuario"
                                    >
                                        <Icon name="lucide:pencil" class="w-4 h-4" />
                                    </button>
                                    <button 
                                        class="btn btn-square btn-ghost btn-sm text-slate-400 hover:text-violet-600 hover:bg-violet-50"
                                        data-action="password"
                                        data-id={p.id}
                                        data-name={p.name}
                                        title="Cambiar Contraseña"
                                    >
                                        <Icon name="lucide:key-round" class="w-4 h-4" />
                                    </button>
                                    <button 
                                        class="btn btn-square btn-ghost btn-sm text-slate-400 hover:text-blue-600 hover:bg-blue-50"
                                        data-action="role"
                                        data-id={p.id}
                                        data-name={p.name}
                                        data-role={p.role}
                                        title="Cambiar Rol"
                                    >
                                        <Icon name="lucide:shield-check" class="w-4 h-4" />
                                    </button>
                                    <button 
                                        class="btn btn-square btn-ghost btn-sm text-slate-400 hover:text-red-600 hover:bg-red-50"
                                        data-action="delete"
                                        data-id={p.id}
                                        data-name={p.name}
                                        title="Eliminar Usuario"
                                    >
                                        <Icon name="lucide:trash-2" class="w-4 h-4" />
                                    </button>
                                </div>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
            ) : (
                <div class="py-16 text-center">
                    <p class="text-slate-400 italic">
                        {hasFilters ? 'No hay usuarios con esos filtros.' : 'No hay usuarios registrados.'}
                    </p>
                    {hasFilters && (
                        <a href="/dashboard/usuarios" class="btn btn-ghost btn-sm mt-4">Ver todos</a>
                    )}
                </div>
            )}
        </div>
    </div>

    <!-- MODAL CREAR USUARIO -->
    <dialog id="create_modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box bg-white rounded-[2.5rem] p-10 border-none shadow-2xl max-w-lg">
            <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-6">
                <Icon name="lucide:user-plus" class="w-8 h-8" />
            </div>
            <h3 class="text-3xl font-black italic uppercase tracking-tighter text-slate-900 mb-2">
                Nuevo <span class="text-emerald-600">Usuario</span>
            </h3>
            <p class="text-slate-500 text-sm font-medium mb-8">
                Crea una cuenta con correo institucional. El usuario podrá iniciar sesión de inmediato.
            </p>

            <form method="POST" action={actions.createUser} class="space-y-5" id="form-create-user">
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Nombre completo</span></label>
                    <input name="name" type="text" required minlength="3" class="input input-bordered w-full rounded-2xl font-bold" placeholder="Ej: María García" />
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Correo @unilibre.edu.co</span></label>
                    <input name="email" type="email" required class="input input-bordered w-full rounded-2xl font-bold" placeholder="usuario@unilibre.edu.co" />
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Contraseña inicial (mín. 6)</span></label>
                    <input name="password" type="password" required minlength="8" class="input input-bordered w-full rounded-2xl font-bold" placeholder="••••••••" autocomplete="new-password" />
                    <p class="text-[10px] text-slate-500 mt-1">Mín. 8 caracteres: mayúscula, minúscula, número y símbolo (! @ * # …).</p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Programa</span></label>
                        <select name="program_id" required class="select select-bordered w-full rounded-2xl font-bold">
                            <option value="">Selecciona...</option>
                            {programs?.map(p => <option value={p.id}>{p.name}</option>)}
                        </select>
                    </div>
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Semestre</span></label>
                        <input name="semester" type="number" min="1" max="12" required class="input input-bordered w-full rounded-2xl font-bold" placeholder="1" value="1" />
                    </div>
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Rol</span></label>
                    <select name="role" required class="select select-bordered w-full rounded-2xl font-bold">
                        <option value="player">Estudiante (player)</option>
                        <option value="preseleccion">Preselección</option>
                        <option value="docente">Docente</option>
                        <option value="admin">Administrador</option>
                    </select>
                </div>

                <div class="modal-action flex gap-3 mt-8">
                    <button type="button" class="btn btn-ghost flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest" onclick="create_modal.close()">Cancelar</button>
                    <button type="submit" class="btn bg-emerald-600 hover:bg-emerald-700 text-white flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest border-none">Crear usuario</button>
                </div>
            </form>
        </div>
    </dialog>

    <!-- MODAL CAMBIAR ROL -->
    <dialog id="role_modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box bg-white rounded-[2.5rem] p-10 border-none shadow-2xl">
            <h3 class="text-3xl font-black italic uppercase tracking-tighter text-slate-900 mb-2">
                Cambiar <span class="text-blue-600">Privilegios</span>
            </h3>
            <p class="text-slate-500 text-sm font-medium mb-8">
                Estás modificando el acceso para: <span id="modal_user_name" class="font-black text-slate-900"></span>
            </p>

            <form method="POST" action={actions.updateUserRole} class="space-y-6">
                <input type="hidden" name="player_id" id="modal_player_id" />
                
                <div class="grid grid-cols-1 gap-3">
                    <label class="flex items-center gap-4 p-5 rounded-3xl border-2 border-slate-100 hover:border-blue-100 cursor-pointer transition-all has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50/30 group">
                        <input type="radio" name="role" value="player" class="radio radio-primary" />
                        <div>
                            <p class="font-black uppercase text-xs text-slate-900">Estudiante (Player)</p>
                            <p class="text-[10px] text-slate-500 font-medium italic">Acceso estándar al juego y perfil.</p>
                        </div>
                    </label>

                    <label class="flex items-center gap-4 p-5 rounded-3xl border-2 border-slate-100 hover:border-blue-100 cursor-pointer transition-all has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50/30 group">
                        <input type="radio" name="role" value="preseleccion" class="radio radio-primary" />
                        <div>
                            <p class="font-black uppercase text-xs text-slate-900">Preselección</p>
                            <p class="text-[10px] text-slate-500 font-medium italic">Solo puede realizar la Preselección (no Mente más Rápida ni Silla Caliente).</p>
                        </div>
                    </label>

                    <label class="flex items-center gap-4 p-5 rounded-3xl border-2 border-slate-100 hover:border-blue-100 cursor-pointer transition-all has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50/30 group">
                        <input type="radio" name="role" value="docente" class="radio radio-primary" />
                        <div>
                            <p class="font-black uppercase text-xs text-slate-900">Docente</p>
                            <p class="text-[10px] text-slate-500 font-medium italic">Ver y crear preguntas en el banco; gestionar eventos y salones en vivo.</p>
                        </div>
                    </label>

                    <label class="flex items-center gap-4 p-5 rounded-3xl border-2 border-slate-100 hover:border-blue-100 cursor-pointer transition-all has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50/30 group">
                        <input type="radio" name="role" value="admin" class="radio radio-primary" />
                        <div>
                            <p class="font-black uppercase text-xs text-slate-900">Administrador</p>
                            <p class="text-[10px] text-slate-500 font-medium italic">Control total sobre configuración y seguridad.</p>
                        </div>
                    </label>
                </div>

                <div class="modal-action flex gap-3 mt-10">
                    <button type="button" class="btn btn-ghost flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest" onclick="role_modal.close()">Cancelar</button>
                    <button type="submit" class="btn btn-primary flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest text-white shadow-lg shadow-blue-200">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </dialog>

    <!-- MODAL EDITAR USUARIO -->
    <dialog id="edit_modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box bg-white rounded-[2.5rem] p-10 border-none shadow-2xl">
            <h3 class="text-3xl font-black italic uppercase tracking-tighter text-slate-900 mb-2">
                Editar <span class="text-amber-600">Usuario</span>
            </h3>
            <p class="text-slate-500 text-sm font-medium mb-8">
                Modificando: <span id="edit_modal_user_name" class="font-black text-slate-900"></span>
            </p>

            <form method="POST" action={actions.updatePlayer} class="space-y-6">
                <input type="hidden" name="player_id" id="edit_player_id" />
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Nombre Completo</span></label>
                    <input name="name" id="edit_name" type="text" required minlength="3" class="input input-bordered w-full rounded-2xl font-bold" placeholder="Ej: Pedro Pérez" />
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Programa</span></label>
                    <select name="program_id" id="edit_program_id" required class="select select-bordered w-full rounded-2xl font-bold">
                        <option value="">Selecciona...</option>
                        {programs?.map(p => <option value={p.id}>{p.name}</option>)}
                    </select>
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Semestre (1-12)</span></label>
                    <input name="semester" id="edit_semester" type="number" min="1" max="12" required class="input input-bordered w-full rounded-2xl font-bold" placeholder="1" />
                </div>

                <div class="modal-action flex gap-3 mt-10">
                    <button type="button" class="btn btn-ghost flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest" onclick="edit_modal.close()">Cancelar</button>
                    <button type="submit" class="btn btn-primary flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest text-white shadow-lg shadow-amber-200 border-none">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </dialog>

    <!-- MODAL CAMBIAR CONTRASEÑA -->
    <dialog id="password_modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box bg-white rounded-[2.5rem] p-10 border-none shadow-2xl">
            <div class="w-16 h-16 bg-violet-50 text-violet-600 rounded-2xl flex items-center justify-center mb-6">
                <Icon name="lucide:key-round" class="w-8 h-8" />
            </div>
            <h3 class="text-3xl font-black italic uppercase tracking-tighter text-slate-900 mb-2">
                Nueva <span class="text-violet-600">Contraseña</span>
            </h3>
            <p class="text-slate-500 text-sm font-medium mb-8">
                Estableciendo nueva contraseña para: <span id="password_modal_user_name" class="font-black text-slate-900"></span>
            </p>

            <form method="POST" action={actions.changePassword} class="space-y-6">
                <input type="hidden" name="player_id" id="password_player_id" />
                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-slate-700 uppercase text-[10px]">Nueva contraseña (mín. 8)</span></label>
                    <input name="new_password" type="password" required minlength="8" class="input input-bordered w-full rounded-2xl font-bold" placeholder="••••••••" autocomplete="new-password" />
                    <p class="text-[10px] text-slate-500">Mayúscula, minúscula, número y símbolo.</p>
                </div>

                <div class="modal-action flex gap-3 mt-10">
                    <button type="button" class="btn btn-ghost flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest" onclick="password_modal.close()">Cancelar</button>
                    <button type="submit" class="btn bg-violet-600 hover:bg-violet-700 text-white flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest border-none">Cambiar Contraseña</button>
                </div>
            </form>
        </div>
    </dialog>

    <!-- MODAL ELIMINAR -->
    <dialog id="delete_modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box bg-white rounded-[2.5rem] p-10 border-none shadow-2xl">
            <div class="w-16 h-16 bg-red-50 text-red-600 rounded-2xl flex items-center justify-center mb-6">
                <Icon name="lucide:alert-triangle" class="w-8 h-8" />
            </div>
            
            <h3 class="text-3xl font-black italic uppercase tracking-tighter text-slate-900 mb-2">
                ¿Eliminar <span class="text-red-600">Usuario?</span>
            </h3>
            <p class="text-slate-500 text-sm font-medium mb-2">
                Esta acción es irreversible. Se borrará el perfil de <span id="delete_user_name" class="font-black text-slate-900"></span> y su cuenta de acceso.
            </p>
            <p class="text-[10px] text-red-500 font-bold uppercase tracking-widest mb-10 italic underline decoration-2">¡Peligro: El usuario perderá todo su progreso!</p>

            <form method="POST" action={actions.deleteUser}>
                <input type="hidden" name="player_id" id="delete_player_id" />
                <div class="modal-action flex gap-3">
                    <button type="button" class="btn btn-ghost flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest" onclick="delete_modal.close()">No, mantener</button>
                    <button type="submit" class="btn bg-red-600 hover:bg-red-700 text-white flex-1 rounded-2xl font-black uppercase italic text-xs tracking-widest shadow-lg shadow-red-200 border-none">Sí, eliminar</button>
                </div>
            </form>
        </div>
    </dialog>

</DashboardLayout>

<script is:inline>
    document.getElementById('btn-create-user')?.addEventListener('click', () => {
        const form = document.getElementById('form-create-user');
        if (form instanceof HTMLFormElement) form.reset();
        const sem = form?.querySelector('input[name="semester"]');
        if (sem instanceof HTMLInputElement) sem.value = '1';
        create_modal.showModal();
    });

    document.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.dataset.id;
            const name = btn.dataset.name || '';
            const action = btn.dataset.action;

            if (action === 'edit') {
                document.getElementById('edit_player_id').value = id;
                document.getElementById('edit_modal_user_name').textContent = name;
                document.getElementById('edit_name').value = name;
                document.getElementById('edit_program_id').value = btn.dataset.programId || '';
                document.getElementById('edit_semester').value = btn.dataset.semester || '1';
                edit_modal.showModal();
            } else if (action === 'password') {
                document.getElementById('password_player_id').value = id;
                document.getElementById('password_modal_user_name').textContent = name;
                document.querySelector('#password_modal form input[name="new_password"]').value = '';
                password_modal.showModal();
            } else if (action === 'role') {
                document.getElementById('modal_player_id').value = id;
                document.getElementById('modal_user_name').textContent = name;
                const radios = document.getElementsByName('role');
                radios.forEach(r => { r.checked = (r.value === btn.dataset.role); });
                role_modal.showModal();
            } else if (action === 'delete') {
                document.getElementById('delete_player_id').value = id;
                document.getElementById('delete_user_name').textContent = name;
                delete_modal.showModal();
            }
        });
    });
</script>
