---
import "../styles/global.css";
import { checkLoginRateLimit, recordLoginFailure } from "../lib/rateLimit";
import { normalizeInstitutionalEmail } from "../lib/institutionalEmail";

let errorMessage = "";

// Lógica de servidor para procesar el formulario
if (Astro.request.method === "POST") {
	try {
		const { allowed, retryAfter } = checkLoginRateLimit(Astro.request);
		if (!allowed) {
			errorMessage = `Demasiados intentos fallidos. Espera ${Math.ceil((retryAfter ?? 0) / 60)} minutos e intenta de nuevo.`;
		} else {
			const formData = await Astro.request.formData();
			const rawEmail = formData.get("email")?.toString();
			const password = formData.get("password")?.toString();

			if (rawEmail && password) {
				const normalized = normalizeInstitutionalEmail(rawEmail);
				if ("error" in normalized) {
					recordLoginFailure(Astro.request);
					errorMessage = normalized.error;
				} else {
					const { error } = await Astro.locals.supabase.auth.signInWithPassword({
						email: normalized.email,
						password,
					});

					if (error) {
						recordLoginFailure(Astro.request);
						errorMessage = "Correo o contraseña incorrectos";
					} else {
						return Astro.redirect("/dashboard");
					}
				}
			}
		}
	} catch (e) {
		errorMessage = "Error al conectar con el servidor";
	}
}
---

<html lang="es">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width" />
	<title>Login - Unilibre Games</title>
	<style is:global>
		@keyframes gradient-shift {
			0%, 100% { background-position: 0% 50%; }
			50% { background-position: 100% 50%; }
		}
		@keyframes float-1 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			33% { transform: translate(30px, -20px) scale(1.05); }
			66% { transform: translate(-20px, 20px) scale(0.95); }
		}
		@keyframes float-2 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			33% { transform: translate(-40px, 15px) scale(1.08); }
			66% { transform: translate(25px, -25px) scale(0.92); }
		}
		@keyframes float-3 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			50% { transform: translate(-15px, -30px) scale(1.03); }
		}
		.login-bg {
			position: fixed;
			inset: 0;
			z-index: -1;
			overflow: hidden;
		}
		.login-bg-base {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				135deg,
				#0a0a0b 0%,
				#18181b 25%,
				#27272a 50%,
				#18181b 75%,
				#0a0a0b 100%
			);
			background-size: 400% 400%;
			animation: gradient-shift 12s ease infinite;
		}
		.login-bg-orb {
			position: absolute;
			border-radius: 50%;
			filter: blur(80px);
			opacity: 0.4;
			animation-duration: 18s;
			animation-timing-function: ease-in-out;
			animation-iteration-count: infinite;
		}
		.login-bg-orb-1 {
			width: 320px;
			height: 320px;
			background: #004a99;
			top: 10%;
			left: 15%;
			animation-name: float-1;
		}
		.login-bg-orb-2 {
			width: 280px;
			height: 280px;
			background: #d9232e;
			top: 55%;
			right: 10%;
			animation-name: float-2;
			animation-delay: -6s;
		}
		.login-bg-orb-3 {
			width: 200px;
			height: 200px;
			background: #1e3a5f;
			bottom: 20%;
			left: 25%;
			animation-name: float-3;
			animation-delay: -3s;
			animation-duration: 14s;
		}
	</style>
</head>
<body class="text-white flex min-h-screen items-center justify-center p-4 relative">
	<div class="login-bg" aria-hidden="true">
		<div class="login-bg-base"></div>
		<div class="login-bg-orb login-bg-orb-1"></div>
		<div class="login-bg-orb login-bg-orb-2"></div>
		<div class="login-bg-orb login-bg-orb-3"></div>
	</div>
<div class="w-full max-w-sm relative z-10">
	<div class="text-center mb-8">
		<h1 class="text-5xl font-black italic tracking-tighter text-unilibre-blue">
			UNILIBRE <span class="text-unilibre-red font-normal">GAMES</span>
		</h1>
		<p class="text-zinc-500 text-sm mt-2 font-medium uppercase tracking-widest">La carrera del saber</p>
	</div>

	<form id="login-form" method="POST" class="bg-zinc-900 border border-zinc-800 p-8 rounded-2xl shadow-2xl space-y-5">
		{errorMessage && (
			<div class="bg-red-500/10 border border-red-500 text-red-500 text-xs p-3 rounded-lg font-bold text-center">
				{errorMessage}
			</div>
		)}

		<div class="space-y-2">
			<label class="text-xs font-bold text-zinc-400 uppercase">Correo Institucional</label>
			<input
				name="email"
				type="text"
				required
				class="w-full bg-zinc-800 border-none rounded-xl p-3 focus:ring-2 focus:ring-unilibre-blue outline-none transition-all"
				placeholder="usuario o usuario@unilibre.edu.co"
				autocomplete="email"
			/>
			<p class="text-[11px] text-zinc-500">
				Puedes escribir solo tu usuario (sin @unilibre.edu.co); se completa automáticamente.
			</p>
		</div>

		<div class="space-y-2">
			<label class="text-xs font-bold text-zinc-400 uppercase">Contraseña</label>
			<input
				name="password"
				type="password"
				required
				class="w-full bg-zinc-800 border-none rounded-xl p-3 focus:ring-2 focus:ring-unilibre-blue outline-none transition-all"
			/>
		</div>

		<button
			id="login-btn"
			type="submit"
			class="w-full bg-unilibre-blue hover:bg-blue-600 text-white font-black py-4 rounded-xl transition-all shadow-lg active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed disabled:active:scale-100 flex items-center justify-center gap-2"
		>
			<span id="login-btn-text">INICIAR SESIÓN</span>
			<span id="login-btn-spinner" class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
		</button>

		<p class="text-center text-zinc-500 text-sm">
			<a href="/recuperar-clave" class="text-unilibre-blue font-bold hover:underline">¿Olvidaste tu contraseña?</a>
		</p>

		<p class="text-center text-zinc-500 text-sm mt-4">
			¿No tienes cuenta? <a href="/registro" class="text-unilibre-blue font-bold hover:underline">Regístrate</a>
		</p>
	</form>
</div>
<script>
	document.getElementById('login-form')?.addEventListener('submit', function() {
		const btn = document.getElementById('login-btn');
		const text = document.getElementById('login-btn-text');
		const spinner = document.getElementById('login-btn-spinner');
		if (btn && text && spinner) {
			btn.disabled = true;
			text.textContent = 'Procesando...';
			spinner.classList.remove('hidden');
		}
	});
</script>
</body>
</html>