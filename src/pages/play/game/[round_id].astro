---
import PlayLayout from "../../../layouts/PlayLayout.astro";
import { actions } from "astro:actions";
import { Icon } from 'astro-icon/components';
import { supabaseAdmin } from "../../../lib/supabaseAdmin";
import { seededShuffle } from "../../../lib/utils";

const { round_id } = Astro.params;
const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

// 1. Obtener datos de la Ronda y Pregunta
const { data: round } = await Astro.locals.supabase
    .from('event_rounds')
    .select('*, events(name, game_mode_id), questions(*, game_levels(points, time_limit), answers(*))')
    .eq('id', round_id)
    .single();

const isJuegoFinal = round?.events?.game_mode_id === 2;

if (!round) return Astro.redirect("/play?error=ronda_no_encontrada");
// Preselección: el estudiante solo sale cuando el docente termina o no hay más preguntas de nivel 1 (ronda finished)
if (round.status === 'finished') return Astro.redirect(`/play/results/${round_id}`);
if (round.status !== 'active') return Astro.redirect(`/play/waiting/${round_id}`);

// 2. Obtener Perfil e Identificar Sesión
const { data: player } = await Astro.locals.supabase
    .from('players').select('id, name').eq('auth_user_id', user.id).single();

if (!player) return Astro.redirect("/");

// Verificar que el jugador se unió a esta ronda (está en event_players)
const { data: inEvent } = await Astro.locals.supabase
    .from('event_players')
    .select('player_id')
    .eq('event_id', round.event_id)
    .eq('player_id', player.id)
    .maybeSingle();

if (!inEvent) return Astro.redirect("/play?error=debes_unirte_con_pin");

// Preselección: el estudiante solo sale cuando la ronda está finished (docente terminó). No bloquear por sesión finalizada.
const isPreseleccion = round?.events?.game_mode_id === 1;

// Sesión obligatoria para enviar respuestas
let { data: gameSession } = await Astro.locals.supabase
    .from('game_sessions')
    .select('id, score')
    .eq('player_id', player.id)
    .eq('event_id', round.event_id)
    .eq('finished', false)
    .maybeSingle();

// Plan de rescate: si no hay sesión, usar upsert (evita duplicate key si ya existe por joinRoom)
if (!gameSession && player) {
    const { data: newS, error: sessErr } = await supabaseAdmin
        .from('game_sessions')
        .upsert({
            player_id: player.id,
            event_id: round.event_id,
            round_id: round.id,
            session_type: 'classroom',
            finished: false,
        }, { onConflict: 'player_id, event_id, finished' })
        .select()
        .single();
    if (!sessErr) gameSession = newS;
}

// Comodines: solo para juego final (Clásico)
let lifelines: { id: number; name: string; code: string | null }[] = [];
let usedLifelinesInRound: string[] = [];
if (round?.events?.game_mode_id === 2) {
    const { data } = await Astro.locals.supabase.from('lifelines').select('id, name, code').order('name', { ascending: true });
    lifelines = data || [];
    const { data: usage } = await supabaseAdmin
        .from('round_lifeline_usage')
        .select('lifeline_code')
        .eq('round_id', parseInt(String(round_id)));
    usedLifelinesInRound = [...new Set((usage || []).map((u) => u.lifeline_code))];
}

// Preselección y Clásico: orden aleatorio por pregunta (cambia cada vez que se lanza una pregunta)
const displayAnswers = round?.questions?.answers
    ? seededShuffle(round.questions.answers, (round.id || 0) * 31 + (round.current_question_id || 0))
    : [];

// 3. Procesar resultado de la acción
const result = Astro.getActionResult(actions.submitAnswer);
const withdrawResult = Astro.getActionResult(actions.withdrawFromSillaCaliente);
if (withdrawResult?.data?.success) {
    return Astro.redirect(`/play/results/${round_id}`);
}
const hasResponded = result?.data?.success || false;
const isCorrect = result?.data?.correct || false;
const submitError = result?.error?.message;
// Log para debug (se envía al cliente)
const debugResult = result ? {
    success: result.data?.success,
    error: result.error?.message,
    insertId: result.data?.insertId,
    points: result.data?.points,
    time: result.data?.time
} : null;
---

<PlayLayout title="¡Carrera en Vivo!">
    <style>
        /* Ocultar scrollbar en barra de comodines (móvil) */
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        /* Parpadeo: quitar transition para que la animación se vea (transition-all del botón lo ocultaba) */
        .option-btn.flash-green,
        .option-btn.flash-red,
        .option-btn.flash-correct {
            animation-fill-mode: both;
            transition: none !important;
        }
        /* Parpadeo: verde=acierto, rojo=tu respuesta errónea, amarillo=respuesta correcta (Preselección y Juego final) */
        @keyframes flash-green-black {
            0%, 35%, 65%, 100% { background-color: #22c55e !important; border-color: #22c55e !important; }
            50% { background-color: #18181b !important; border-color: #3f3f46 !important; }
        }
        @keyframes flash-red-black {
            0%, 35%, 65%, 100% { background-color: #ef4444 !important; border-color: #ef4444 !important; }
            50% { background-color: #18181b !important; border-color: #3f3f46 !important; }
        }
        @keyframes flash-correct-yellow {
            0%, 35%, 65%, 100% { background-color: #eab308 !important; border-color: #eab308 !important; }
            50% { background-color: #18181b !important; border-color: #3f3f46 !important; }
        }
        .option-btn.flash-green {
            animation: flash-green-black 0.7s ease-in-out 5;
        }
        .option-btn.flash-red {
            animation: flash-red-black 0.7s ease-in-out 5;
        }
        .option-btn.flash-correct {
            animation: flash-correct-yellow 0.7s ease-in-out 5;
        }
        /* Juego final: borde azul en todos los lados (el ring se cortaba por overflow-hidden) */
        .option-btn.option-btn-selected {
            border-width: 3px !important;
            border-color: var(--color-primary) !important;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" is:inline></script>
    {debugResult && (
        <script define:vars={{ debugResult }}>
            console.log('[submitAnswer] Resultado en navegador:', debugResult);
            if (debugResult.success) console.log('[submitAnswer] Respuesta guardada OK, id:', debugResult.insertId);
            if (debugResult.error) console.error('[submitAnswer] Error:', debugResult.error);
        </script>
    )}

    <div class="flex flex-col min-h-screen h-screen max-h-[100dvh] p-2 sm:p-4 bg-zinc-950 text-white overflow-hidden font-sans">

        <!-- HEADER -->
        <header class="flex justify-between items-center gap-2 bg-zinc-900 border border-zinc-800 p-2 sm:p-4 rounded-xl sm:rounded-[2rem] mb-2 sm:mb-6 shadow-xl flex-shrink-0 flex-nowrap">
            <div class="flex items-center gap-2 sm:gap-4 min-w-0">
                <div class="w-8 h-8 sm:w-10 sm:h-10 flex-shrink-0 bg-primary rounded-lg sm:rounded-xl flex items-center justify-center font-black text-white italic text-sm sm:text-base">
                    {player?.name?.charAt(0).toUpperCase()}
                </div>
                <div class="min-w-0">
                    {isJuegoFinal && player?.name ? (
                        <p class="text-base sm:text-xl md:text-2xl font-black text-white leading-tight truncate">{player.name}</p>
                    ) : (
                        <>
                            <p class="text-[8px] font-black text-zinc-500 uppercase tracking-widest leading-none mb-1">Puntos</p>
                            <p class="text-xl font-black text-primary leading-none tabular-nums">{gameSession?.score || 0}</p>
                        </>
                    )}
                </div>
            </div>
            <div class="flex items-center gap-2 flex-shrink min-w-0 sm:flex-shrink-0">
                {isJuegoFinal && lifelines && lifelines.length > 0 && !hasResponded && (
                    <div id="lifelines-bar" class="flex gap-1 sm:gap-1.5 flex-nowrap overflow-x-auto overflow-y-hidden py-0.5 -mx-1 scrollbar-hide justify-end min-w-0 flex-1 sm:flex-initial">
                        {lifelines.map((l) => {
                            const code = (l.code || '').toLowerCase();
                            const is5050 = code === '5050' || code.includes('50') || (l.name || '').toLowerCase().includes('50');
                            const isCambiar = code === 'cambiar' || code === 'saltar' || (l.name || '').toLowerCase().includes('cambiar');
                            const isPublico = code === 'publico' || (l.name || '').toLowerCase().includes('público') || (l.name || '').toLowerCase().includes('publico');
                            const isLlamada = code === 'llamada' || (l.name || '').toLowerCase().includes('llamada');
                            const lifelineCode = is5050 ? '5050' : isCambiar ? 'cambiar' : isPublico ? 'publico' : isLlamada ? 'llamada' : code;
                            const isUsed = usedLifelinesInRound.includes(lifelineCode);
                            const shortName = is5050 ? '50:50' : isCambiar ? 'Cambiar' : isPublico ? 'Público' : isLlamada ? 'Llamada' : (l.name?.slice(0, 8) || l.name);
                            return (
                                <span
                                    class:list={[
                                        'lifeline-badge px-1.5 py-0.5 sm:px-2 sm:py-1 rounded-md sm:rounded-lg text-[9px] sm:text-xs font-semibold border whitespace-nowrap shrink-0',
                                        isUsed ? 'bg-zinc-800/50 border-zinc-600 text-zinc-500 opacity-60 line-through' : 'bg-amber-500/20 border-amber-500/50 text-amber-400'
                                    ]}
                                    data-code={l.code || ''}
                                    data-name={l.name}
                                    title={l.name}
                                >
                                    {shortName}{isUsed ? ' ✓' : ''}
                                </span>
                            );
                        })}
                    </div>
                )}
                {!isJuegoFinal && (
                    <div id="timer-display" class="text-3xl sm:text-4xl font-black italic text-white tabular-nums">00</div>
                )}
                {isJuegoFinal && gameSession && (
                    <form method="POST" action={actions.withdrawFromSillaCaliente} class="flex-shrink-0" id="withdraw-form">
                        <input type="hidden" name="round_id" value={round_id} />
                        <button type="submit" class="btn btn-sm btn-warning text-zinc-900 font-bold border border-amber-400/60" onclick="return confirm('¿Retirarte y llevarte lo acumulado? Se guardará tu premio y saldrás del juego.');">
                            <Icon name="lucide:log-out" class="w-4 h-4" /> Retirarme
                        </button>
                    </form>
                )}
            </div>
        </header>

        <main class="flex-1 flex flex-col justify-start max-w-4xl mx-auto w-full gap-3 sm:gap-6 md:gap-8 min-h-0 overflow-y-auto overflow-x-hidden py-0 sm:py-2">
            {hasResponded ? (
                    <div class="flex flex-col items-center justify-center text-center animate-in zoom-in duration-300 pt-6 sm:pt-10">
                        <div class:list={["w-32 h-32 rounded-full flex items-center justify-center mb-8 shadow-2xl animate-bounce", isCorrect ? "bg-success" : "bg-error"]}>
                            <Icon name={isCorrect ? "lucide:zap" : "lucide:circle-x"} class="w-16 h-16 text-white" />
                        </div>
                        <h2 class="text-5xl font-black uppercase italic mb-2 tracking-tighter drop-shadow-lg">
                            {isCorrect ? '¡CORRECTO!' : '¡INCORRECTO!'}
                        </h2>
                        <div class="flex gap-4 mt-8">
                            <div class="bg-zinc-900 p-5 rounded-3xl border border-zinc-800 min-w-[120px]">
                                <p class="text-[10px] font-black text-zinc-500 uppercase mb-1">Tiempo</p>
                                <p class="text-2xl font-bold">{result?.data?.time}s</p>
                            </div>
                            {!isJuegoFinal && (
                            <div class="bg-zinc-900 p-5 rounded-3xl border border-zinc-800 min-w-[120px]">
                                <p class="text-[10px] font-black text-zinc-500 uppercase mb-1">Puntos</p>
                                <p class="text-2xl font-black text-primary">+{result?.data?.points}</p>
                            </div>
                            )}
                        </div>
                    </div>
            ) : !gameSession ? (
                    <div class="text-center p-8">
                        <p class="text-amber-500 font-bold">No hay sesión de juego activa. Recarga la página o vuelve a unirte con el PIN.</p>
                        <a href="/play" class="btn btn-primary mt-4">Volver a unirse</a>
                    </div>
            ) : (
                    <div id="question-area" class="space-y-3 sm:space-y-6 md:space-y-10">
                        {submitError && (
                                <div class="p-4 bg-red-500/20 border border-red-500/50 rounded-2xl text-red-400 text-sm font-bold">
                                    Error: {submitError}
                                </div>
                        )}
                        {withdrawResult?.error?.message && (
                            <div class="p-4 bg-amber-500/20 border border-amber-500/50 rounded-2xl text-amber-200 text-sm font-bold">
                                {withdrawResult.error.message}
                            </div>
                        )}
                        <div class="text-center px-1">
                            <h2 class="text-xl min-[400px]:text-2xl sm:text-3xl md:text-5xl font-black leading-tight italic uppercase text-white drop-shadow-2xl break-words">
                                {round?.questions?.question_text}
                            </h2>
                        </div>

                        <form id="game-form" class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
                            <input type="hidden" name="round_id" value={round_id} />
                            <input type="hidden" name="question_id" value={round?.current_question_id} />
                            <input type="hidden" name="session_id" value={gameSession?.id} />

                            {displayAnswers.map((ans: any, idx: number) => (
                                    <button
                                            type="button"
                                            data-answer-id={ans.id}
                                            data-is-correct={ans.is_correct === true ? 'true' : 'false'}
                                            class="option-btn group relative min-h-[3.5rem] sm:min-h-24 md:min-h-28 bg-zinc-900 border-2 border-zinc-800 rounded-xl sm:rounded-2xl text-left min-w-0 hover:border-primary transition-all active:scale-[0.98] shadow-lg touch-manipulation"
                                    >
                                        <div class="flex items-start gap-3 sm:gap-5 px-4 sm:px-6 md:px-8 py-3 relative z-10">
                                    <span class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl sm:rounded-2xl bg-zinc-800 group-hover:bg-primary flex items-center justify-center font-black text-xl sm:text-2xl border border-zinc-700 flex-shrink-0">
                                        {['A','B','C','D'][idx]}
                                    </span>
                                            <span class="font-bold text-base sm:text-lg md:text-xl text-zinc-200 text-left break-words min-w-0 flex-1">{ans.answer_text}</span>
                                        </div>
                                        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    </button>
                            ))}
                        </form>
                    </div>

                    <div id="timeout-area" class="hidden flex-col items-center justify-center text-center animate-in zoom-in">
                        <div class="w-32 h-32 bg-amber-500 rounded-full flex items-center justify-center mb-8 shadow-2xl">
                            <Icon name="lucide:clock-alert" class="w-16 h-16 text-white" />
                        </div>
                        <h2 class="text-5xl font-black text-amber-500 italic uppercase">¡TIEMPO AGOTADO!</h2>
                    </div>

            )}
        </main>

        {!isJuegoFinal && (
            <footer class="mt-4 sm:mt-8 pb-6 sm:pb-10 flex-shrink-0" style="padding-bottom: max(1.5rem, env(safe-area-inset-bottom));">
                <progress id="timer-bar" class="progress progress-primary w-full h-3 sm:h-4 bg-zinc-800 shadow-inner" value="100" max="100"></progress>
            </footer>
        )}
    </div>

    <script define:vars={{ questionId: round?.current_question_id, roundId: round_id, isJuegoFinal }}>
        window.isJuegoFinal = isJuegoFinal;

        const form = document.getElementById('game-form');
        const questionArea = document.getElementById('question-area');
        const mainArea = document.querySelector('main');

        // Polling: comodines solo en juego final; el docente los activa
        let lifeline5050Applied = false;
        async function checkLifelineState() {
            if (!isJuegoFinal) return;
            if (!roundId) return;
            try {
                const r = await fetch(`/api/round-lifeline-state?round_id=${roundId}&question_id=${questionId || ''}`);
                const { used, used_in_round } = await r.json();

                // Marcar comodines usados en la sesión como inactivos
                const usedCodes = (used_in_round || []).map((c) => (c || '').toLowerCase());
                document.querySelectorAll('.lifeline-badge').forEach((b) => {
                    const c = (b.dataset?.code || '').toLowerCase();
                    const n = (b.dataset?.name || '').toLowerCase();
                    const is5050 = c === '5050' || c.includes('50') || n.includes('50') || n.includes('50:50');
                    const isCambiar = c === 'cambiar' || c === 'saltar' || n.includes('cambiar');
                    const isPublico = c === 'publico' || n.includes('público') || n.includes('publico');
                    const isLlamada = c === 'llamada' || n.includes('llamada');
                    const code = is5050 ? '5050' : isCambiar ? 'cambiar' : isPublico ? 'publico' : isLlamada ? 'llamada' : c;
                    const isUsed = usedCodes.includes(code || '');
                    if (isUsed) {
                        b.classList.add('opacity-40', 'line-through', 'text-zinc-500');
                        b.classList.remove('text-amber-400');
                    }
                });

                // Aplicar 50:50 (ocultar 2 respuestas) solo para la pregunta actual
                if (used?.['5050'] && form && !lifeline5050Applied) {
                    const meta = used['5050'];
                    const hideIds = (typeof meta === 'object' && meta?.hide_ids) ? meta.hide_ids : [];
                    if (Array.isArray(hideIds)) {
                        hideIds.forEach((id) => {
                            const opt = form.querySelector(`[data-answer-id="${id}"]`);
                            if (opt) {
                                opt.style.opacity = '0.2';
                                opt.style.pointerEvents = 'none';
                                opt.disabled = true;
                            }
                        });
                    }
                    lifeline5050Applied = true;
                }
                // Última palabra: fondo amarillo en la seleccionada y bloquear cambios
                if (used?.['last_word'] && form) {
                    form.querySelectorAll('.option-btn').forEach((b) => {
                        b.style.pointerEvents = 'none';
                        b.disabled = true;
                        if (b.classList.contains('option-btn-selected')) {
                            b.classList.add('!bg-amber-500/40', '!border-amber-400');
                        }
                    });
                }
            } catch (_) {}
        }
        setInterval(checkLifelineState, 1500);
        checkLifelineState();

        function playResultSound(isCorrect) {
            try {
                const audio = new Audio(isCorrect ? '/correcta.mp3' : '/incorrecta.mp3');
                audio.volume = 0.8;
                audio.play().catch(() => {});
            } catch (_) {}
        }

        function showResult(data) {
            if (!mainArea) return;
            const isCorrect = data?.correct ?? false;
            const resultHtml = `
                <div class="flex flex-col items-center justify-center text-center animate-in zoom-in duration-300 pt-6 sm:pt-10">
                    <div class="w-32 h-32 rounded-full flex items-center justify-center mb-8 shadow-2xl animate-bounce ${isCorrect ? 'bg-success' : 'bg-error'}">
                        <span class="text-6xl">${isCorrect ? '✓' : '✗'}</span>
                    </div>
                    <h2 class="text-5xl font-black uppercase italic mb-2 tracking-tighter drop-shadow-lg">
                        ${isCorrect ? '¡CORRECTO!' : '¡INCORRECTO!'}
                    </h2>
                    <div class="flex gap-4 mt-8">
                        <div class="bg-zinc-900 p-5 rounded-3xl border border-zinc-800 min-w-[120px]">
                            <p class="text-[10px] font-black text-zinc-500 uppercase mb-1">Tiempo</p>
                            <p class="text-2xl font-bold">${data?.time ?? '0'}s</p>
                        </div>
                        <div class="bg-zinc-900 p-5 rounded-3xl border border-zinc-800 min-w-[120px]">
                            <p class="text-[10px] font-black text-zinc-500 uppercase mb-1">Puntos</p>
                            <p class="text-2xl font-black text-primary">+${data?.points ?? 0}</p>
                        </div>
                    </div>
                    <p class="mt-4 text-xs text-zinc-500">Guardado id: ${data?.insertId ?? '-'}</p>
                </div>
            `;
            if (questionArea) questionArea.classList.add('hidden');
            const timeoutArea = document.getElementById('timeout-area');
            if (timeoutArea) timeoutArea.classList.add('hidden');
            mainArea.insertAdjacentHTML('beforeend', resultHtml);
        }

        let verificationAnimating = false;
        async function checkVerificationResult() {
            if (!isJuegoFinal || !roundId || !questionId || verificationAnimating) return;
            try {
                const r = await fetch(`/api/round-lifeline-state?round_id=${roundId}&question_id=${questionId || ''}`);
                const data = await r.json();
                const vr = data?.verification_result;
                if (!vr || String(vr.question_id) !== String(questionId)) return;
                verificationAnimating = true;
                window.verificationAnimating = true;
                const isCorrect = vr.is_correct;
                playResultSound(isCorrect);
                const studentAnswerId = String(vr.student_answer_id);
                const correctAnswerId = String(vr.correct_answer_id);
                const blinkColors = { green: '#22c55e', red: '#ef4444', yellow: '#eab308' };
                const dark = '#18181b';
                let tick = 0;
                const blink = setInterval(() => {
                    const on = tick % 2 === 0;
                    form?.querySelectorAll('.option-btn').forEach((b) => {
                        const aid = b.getAttribute('data-answer-id');
                        b.classList.remove('!bg-amber-500/40', 'border-amber-400');
                        b.style.transition = 'none';
                        if (aid === studentAnswerId) {
                            b.style.backgroundColor = on ? (isCorrect ? blinkColors.green : blinkColors.red) : dark;
                            b.style.borderColor = on ? (isCorrect ? blinkColors.green : blinkColors.red) : '#3f3f46';
                        } else if (aid === correctAnswerId && !isCorrect) {
                            b.style.backgroundColor = on ? blinkColors.yellow : dark;
                            b.style.borderColor = on ? blinkColors.yellow : '#3f3f46';
                        }
                    });
                    tick++;
                    if (tick >= 6) clearInterval(blink);
                }, 450);
                if (isCorrect && typeof confetti === 'function') {
                    confetti({ particleCount: 50, spread: 55, origin: { y: 0.6 } });
                }
                const isFinished = data?.round_status === 'finished';
                const delayMs = isCorrect ? 4500 : 5500;
                setTimeout(() => {
                    if (isFinished) window.location.href = `/play/results/${roundId}`;
                    else window.location.reload();
                }, delayMs);
            } catch (_) {}
        }
        setInterval(checkVerificationResult, 800);

        if (form) {
            form.querySelectorAll('.option-btn').forEach((btn) => {
                btn.addEventListener('click', async (e) => {
                    const target = e.currentTarget;
                    const answerId = target?.dataset?.answerId;
                    if (!answerId) return;

                    if (isJuegoFinal) {
                        // Juego final: solo marcar, no enviar. El docente evalúa. Borde azul en todos los lados.
                        form.querySelectorAll('.option-btn').forEach((b) => {
                            b.classList.remove('option-btn-selected');
                        });
                        target.classList.add('option-btn-selected');
                        try {
                            await fetch('/api/student-select-answer', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ round_id: roundId, question_id: questionId, answer_id: answerId }),
                            });
                        } catch (_) {}
                        return;
                    }

                    if (form.dataset.submitting === '1') return;
                    form.dataset.submitting = '1';
                    window.gameAnswered = true;
                    form.querySelectorAll('.option-btn').forEach((b) => {
                        b.disabled = true;
                        b.style.opacity = '0.5';
                    });

                    const formData = new FormData(form);
                    formData.set('answer_id', answerId);

                    try {
                        const res = await fetch('/api/submit-answer', { method: 'POST', body: formData });
                        const data = await res.json();
                        if (!res.ok) {
                            const errMsg = data?.error || res.statusText || '';
                            if (/duplicate|duplicad/i.test(errMsg)) {
                                showResult(data?.correct != null ? data : { correct: false, points: 0 });
                                return;
                            }
                            alert('Error: ' + errMsg);
                            form.dataset.submitting = '0';
                            window.gameAnswered = false;
                            form.querySelectorAll('.option-btn').forEach((b) => { b.disabled = false; b.style.opacity = '1'; });
                            return;
                        }
                        // Preselección: sonido al evaluar, parpadeo y confetti una sola vez si acertó
                        if (!isJuegoFinal && form) {
                            playResultSound(data.correct);
                            form.querySelectorAll('.option-btn').forEach((b) => { b.style.opacity = '1'; });
                            const blinkColors = { green: '#22c55e', red: '#ef4444', yellow: '#eab308' };
                            const dark = '#18181b';
                            let tick = 0;
                            const blink = setInterval(() => {
                                const on = tick % 2 === 0;
                                form.querySelectorAll('.option-btn').forEach((b) => {
                                    const aid = b.getAttribute('data-answer-id');
                                    const isCorrectAns = b.getAttribute('data-is-correct') === 'true';
                                    if (aid === answerId) {
                                        b.style.transition = 'none';
                                        b.style.backgroundColor = on ? (data.correct ? blinkColors.green : blinkColors.red) : dark;
                                        b.style.borderColor = on ? (data.correct ? blinkColors.green : blinkColors.red) : '#3f3f46';
                                    } else if (!data.correct && isCorrectAns) {
                                        b.style.transition = 'none';
                                        b.style.backgroundColor = on ? blinkColors.yellow : dark;
                                        b.style.borderColor = on ? blinkColors.yellow : '#3f3f46';
                                    }
                                });
                                tick++;
                                if (tick >= 6) { clearInterval(blink); setTimeout(() => showResult(data ?? {}), 400); }
                            }, 450);
                            if (data.correct && typeof confetti === 'function') {
                                confetti({ particleCount: 50, spread: 55, origin: { y: 0.6 } });
                            }
                        } else {
                            playResultSound(data?.correct ?? false);
                            showResult(data ?? {});
                        }
                    } catch (err) {
                        console.error('[submitAnswer] Excepción:', err);
                        alert('Error al enviar: ' + (err instanceof Error ? err.message : String(err)));
                        form.dataset.submitting = '0';
                    }
                });
            });
        }
    </script>
    {hasResponded && (
        <script is:inline define:vars={{ isCorrect }}>
            (function() {
                try {
                    var a = new Audio(isCorrect ? '/correcta.mp3' : '/incorrecta.mp3');
                    a.volume = 0.8;
                    a.play().catch(function() {});
                } catch (e) {}
            })();
        </script>
    )}
    <script is:inline define:vars={{ roundId: round_id, currentQ: round?.current_question_id, startTime: round?.question_started_at, limit: isPreseleccion ? 30 : (round?.questions?.game_levels?.time_limit || 30), isJuegoFinal }}>
        window.isJuegoFinal = isJuegoFinal;
        let isDone = false;

        // SINCRONIZACIÓN - Verificar nueva pregunta o fin de ronda (evitar reload por null transitorio)
        async function sync() {
            if (window.verificationAnimating) return;
            const client = window.supabaseClient;
            if (!client) return;
            const { data } = await client.from('event_rounds').select('current_question_id, status').eq('id', roundId).maybeSingle();

            if (data) {
                const newQ = data.current_question_id;
                if (newQ != null && String(newQ) !== String(currentQ)) {
                    isDone = true;
                    window.location.href = window.location.pathname;
                    return;
                }
                if (data.status === 'finished') {
                    isDone = true;
                    window.location.href = `/play/results/${roundId}`;
                }
            }
        }
        setInterval(sync, 3000);

        // TIMER - Solo en preselección; en juego final no hay tiempo, va al ritmo del docente
        const bar = document.getElementById('timer-bar');
        const txt = document.getElementById('timer-display');
        const questionUI = document.getElementById('question-area');
        const timeoutUI = document.getElementById('timeout-area');

        if (!isJuegoFinal && bar && startTime && !document.querySelector('.animate-bounce')) {
            const start = new Date(startTime).getTime();
            const total = limit * 1000;
            function update() {
                const now = new Date().getTime();
                const rem = Math.max(0, total - (now - start));
                if (bar) bar.value = (rem / total) * 100;
                if (txt) txt.innerText = Math.ceil(rem / 1000).toString().padStart(2, '0');

                if (rem <= 0 && !isDone && !window.gameAnswered) {
                    isDone = true;
                    if (questionUI) questionUI.classList.add('hidden');
                    if (timeoutUI) {
                        timeoutUI.classList.remove('hidden');
                        timeoutUI.classList.add('flex');
                    }
                } else if (!isDone && !window.gameAnswered) {
                    requestAnimationFrame(update);
                }
            }
            update();
        }
    </script>
</PlayLayout>